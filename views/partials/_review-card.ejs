<article class="review-card">
  <div class="review-stars">
    <% for (let i = 0; i < 5; i++) { %>
      <svg class="star<%= i < review.rating ? ' star-filled' : '' %>" width="18" height="18" viewBox="0 0 24 24" fill="<%= i < review.rating ? '#F59E0B' : 'none' %>" stroke="<%= i < review.rating ? '#F59E0B' : '#718096' %>" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
    <% } %>
  </div>
  <p class="review-text">"<%= l(review, 'text') %>"</p>
  <div class="review-author">
    <div class="review-author-info">
      <strong><%= review.author %></strong>
      <span class="review-country"><%= review.country %></span>
    </div>
    <% if (typeof hikeName !== 'undefined' && hikeName) { %>
      <span class="review-hike"><%= hikeName %></span>
    <% } %>
  </div>
</article>
