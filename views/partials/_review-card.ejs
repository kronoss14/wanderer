<article class="review-card">
  <div class="rating" aria-label="<%= review.rating %> out of 5 stars">
    <% for (let i = 0; i < 5; i++) { %>
      <% if (i < review.rating) { %>
        <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      <% } else { %>
        <svg viewBox="0 0 24 24" class="rating-empty"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      <% } %>
    <% } %>
  </div>
  <blockquote>&ldquo;<%= l(review, 'text') %>&rdquo;</blockquote>
  <footer>
    <div class="review-avatar"><%= (review.author || '?').charAt(0).toUpperCase() %></div>
    <div>
      <div class="review-author"><%= review.author %><% if (review.country) { %> · <span style="color: var(--text-muted); font-weight: 500"><%= review.country %></span><% } %></div>
      <% if (typeof hikeName !== 'undefined' && hikeName) { %>
        <div style="font-size: var(--text-xs); color: var(--text-muted); margin-top: 2px"><%= hikeName %></div>
      <% } %>
    </div>
  </footer>
</article>
