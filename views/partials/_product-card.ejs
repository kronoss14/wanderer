<article class="product-card">
  <a href="<%= langPrefix %>/shop/<%= product.id %>" class="product-card-media">
    <% if (product.image) { %>
      <img src="<%= product.image %>" alt="<%= l(product, 'name') %>" loading="lazy">
    <% } else { %>
      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--stone-400)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
    <% } %>
  </a>
  <div class="product-card-body">
    <span class="product-card-cat"><%= product.category || (lang === 'en' ? 'Gear' : 'აღჭურვილობა') %></span>
    <h3 class="product-card-name"><a href="<%= langPrefix %>/shop/<%= product.id %>"><%= l(product, 'name') %></a></h3>
    <div class="product-card-price">
      ₾<%= product.price %>
      <% if (product.originalPrice && product.originalPrice > product.price) { %>
        <s>₾<%= product.originalPrice %></s>
      <% } %>
    </div>
    <% if (product.inStock === false) { %>
      <span class="product-card-oos"><%= lang === 'en' ? 'Out of stock' : 'ამოიწურა' %></span>
    <% } else { %>
      <button class="btn btn-outline btn-sm btn-add-cart" data-product-id="<%= product.id %>" data-product-name="<%= l(product, 'name') %>" data-product-price="<%= product.price %>" data-product-image="<%= product.image || '' %>">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
        <%= lang === 'en' ? 'Add to cart' : 'დამატება' %>
      </button>
    <% } %>
  </div>
</article>
