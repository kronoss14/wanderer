<article class="product-card">
  <a href="<%= langPrefix %>/shop/<%= product.id %>" class="product-card-link">
    <div class="product-card-image">
      <% if (product.image) { %>
        <img src="<%= product.image %>" alt="<%= l(product, 'name') %>" loading="lazy">
      <% } else { %>
        <div class="product-card-placeholder">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
        </div>
      <% } %>
      <span class="product-card-badge badge-<%= product.category %>"><%= t('shop.category.' + product.category) %></span>
      <% if (product.originalPrice && product.originalPrice > product.price) { %>
        <span class="product-card-discount">-<%= Math.round((1 - product.price / product.originalPrice) * 100) %>%</span>
      <% } %>
    </div>
    <div class="product-card-body">
      <h3 class="product-card-title"><%= l(product, 'name') %></h3>
      <div class="product-card-price-row">
        <% if (product.originalPrice && product.originalPrice > product.price) { %>
          <span class="product-card-original-price">&#8382;<%= product.originalPrice %></span>
        <% } %>
        <span class="product-card-price">&#8382;<%= product.price %></span>
      </div>
    </div>
  </a>
  <button class="btn btn-primary btn-add-cart" data-product-id="<%= product.id %>" data-product-name="<%= l(product, 'name') %>" data-product-price="<%= product.price %>" data-product-image="<%= product.image || '' %>">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
    <%= t('shop.add_to_cart') %>
  </button>
</article>
