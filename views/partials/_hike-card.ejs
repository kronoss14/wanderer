<% const dates = Array.isArray(hike.dates) ? hike.dates : (hike.date ? [hike.date] : []); %>
<article class="card hike-card">
  <a href="<%= langPrefix %>/hikes/<%= hike.id %>" style="display:flex; flex-direction:column; flex:1; color: inherit">
    <div class="card-media">
      <img src="<%= hike.cardImage || hike.heroImage || (hike.images && hike.images[0]) || '/images/hikes-hero.jpeg' %>" alt="<%= l(hike, 'name') %>" loading="lazy">
      <div class="card-media-badges">
        <% if (hike.featured) { %>
          <span class="badge badge-accent">★ <%= lang === 'en' ? 'Featured' : 'რეკომენდებული' %></span>
        <% } %>
        <span class="badge diff-<%= hike.difficulty || 'medium' %>">
          <%= lang === 'en'
              ? (hike.difficulty === 'easy' ? 'Easy' : hike.difficulty === 'hard' ? 'Advanced' : 'Moderate')
              : (hike.difficulty === 'easy' ? 'მარტივი' : hike.difficulty === 'hard' ? 'რთული' : 'საშუალო') %>
        </span>
      </div>
      <% if (hike.price) { %>
        <span class="card-media-price">₾<%= hike.price %> <small><%= lang === 'en' ? '/ person' : '/ კაცი' %></small></span>
      <% } %>
    </div>
    <div class="card-body">
      <div>
        <span class="badge badge-outline" style="margin-bottom: 6px"><%= l(hike, 'region') %></span>
        <h3 class="card-title"><%= l(hike, 'name') %></h3>
      </div>
      <% const summary = l(hike, 'summary') || (l(hike, 'description') || '').slice(0, 120); %>
      <% if (summary) { %>
        <p class="card-excerpt"><%= summary %></p>
      <% } %>
      <div class="card-meta">
        <% if (l(hike, 'duration')) { %>
        <span class="card-meta-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <%= l(hike, 'duration') %>
        </span>
        <% } %>
        <% if (hike.distance) { %>
        <span class="card-meta-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3h13v13"/><path d="M21 3L3 21"/></svg>
          <%= hike.distance %>
        </span>
        <% } %>
        <% if (hike.groupSize) { %>
        <span class="card-meta-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
          <%= hike.groupSize %>
        </span>
        <% } %>
        <% if (dates.length) { %>
        <span class="card-meta-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <%= dates.slice(0,2).map(d => new Date(d).toLocaleDateString(lang === 'en' ? 'en-US' : 'ka-GE', { day: 'numeric', month: 'short' })).join(', ') %>
        </span>
        <% } %>
      </div>
    </div>
  </a>
</article>
