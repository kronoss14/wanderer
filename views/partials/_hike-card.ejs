<article class="hike-card">
  <a href="<%= langPrefix %>/hikes/<%= hike.id %>" class="hike-card-link">
    <div class="hike-card-image">
      <img src="<%= hike.cardImage %>" alt="<%= l(hike, 'name') %>" loading="lazy">
      <span class="hike-card-badge badge-<%= hike.type %>"><%= t('hike.type.' + hike.type) %></span>
      <div class="hike-card-overlay"></div>
    </div>
    <div class="hike-card-body">
      <h3 class="hike-card-title"><%= l(hike, 'name') %></h3>
      <p class="hike-card-region"><%= l(hike, 'region') %></p>
      <% const dates = Array.isArray(hike.dates) ? hike.dates : (hike.date ? [hike.date] : []); %>
      <% if (dates.length) { %>
        <p class="hike-card-date">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--accent-orange)" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <%= dates.map(d => new Date(d).toLocaleDateString(lang === 'en' ? 'en-US' : 'ka-GE', { day: 'numeric', month: 'short' })).join(', ') %>
        </p>
      <% } %>
      <p class="hike-card-summary"><%= l(hike, 'summary') %></p>
      <div class="hike-card-meta">
        <span class="meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <%= l(hike, 'duration') %>
        </span>
        <span class="meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
          <%= hike.groupSize %>
        </span>
        <% if (dates.length) { %>
          <span class="meta-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <%= dates.map(d => new Date(d).toLocaleDateString(lang === 'en' ? 'en-US' : 'ka-GE', { day: 'numeric', month: 'short' })).join(', ') %>
          </span>
        <% } %>
        <span class="meta-item price">&#8382;<%= hike.price %></span>
      </div>
    </div>
  </a>
</article>
