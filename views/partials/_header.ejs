<div class="announcement-bar">
  <div class="container">
    <span>🏔️ <%= lang === 'en' ? 'Certified guides · Small groups · Unforgettable adventures across Georgia' : 'სერტიფიცირებული გამყოლები · მცირე ჯგუფები · დაუვიწყარი თავგადასავლები საქართველოში' %></span>
    &nbsp;·&nbsp;<a href="<%= langPrefix %>/contact"><%= t('nav.contact') %> →</a>
  </div>
</div>

<header class="site-header" id="site-header">
  <div class="container header-inner">
    <a href="<%= langPrefix %>/" class="logo" aria-label="Wanderer — Home">
      <img src="/images/logo.jpg" alt="" class="logo-img" loading="eager">
      <div class="logo-text">
        <span class="logo-name">Wanderer</span>
        <span class="logo-name-geo">მოხეტიალე</span>
      </div>
    </a>
    <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false" aria-controls="main-nav">
      <span class="hamburger"></span>
    </button>
    <nav class="main-nav" id="main-nav">
      <ul class="nav-list">
        <li><a href="<%= langPrefix %>/hikes" class="nav-link<%= currentPath.startsWith('/hikes') ? ' active' : '' %>"><%= t('nav.hikes') %></a></li>
        <li><a href="<%= langPrefix %>/map" class="nav-link<%= currentPath === '/map' ? ' active' : '' %>"><%= t('nav.map') %></a></li>
        <li><a href="<%= langPrefix %>/gallery" class="nav-link<%= currentPath.startsWith('/gallery') ? ' active' : '' %>"><%= t('nav.gallery') %></a></li>
        <li><a href="<%= langPrefix %>/reviews" class="nav-link<%= currentPath === '/reviews' ? ' active' : '' %>"><%= t('nav.reviews') %></a></li>
        <li><a href="<%= langPrefix %>/about" class="nav-link<%= currentPath === '/about' ? ' active' : '' %>"><%= t('nav.about') %></a></li>
        <li><a href="<%= langPrefix %>/contact" class="nav-link<%= currentPath === '/contact' ? ' active' : '' %>"><%= t('nav.contact') %></a></li>
        <li><a href="<%= langPrefix %>/shop" class="nav-link nav-shop<%= currentPath.startsWith('/shop') ? ' active' : '' %>"><%= t('nav.shop') %></a></li>
      </ul>
      <a href="<%= langPrefix %>/cart" class="cart-link" aria-label="Cart">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
        <span class="cart-badge" style="display:none;">0</span>
      </a>
      <div class="nav-social">
        <a href="<%= socialLinks.facebook %>" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="social-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="<%= socialLinks.instagram %>" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
      </div>
      <div class="nav-lang">
        <% if (lang === 'ka') { %>
          <a href="/en<%= currentPath %>" class="lang-switch" aria-label="English">EN</a>
        <% } else { %>
          <a href="<%= currentPath %>" class="lang-switch" aria-label="Georgian">KA</a>
        <% } %>
      </div>
    </nav>
  </div>
</header>
