<section class="page-hero" style="min-height: 400px">
  <div class="page-hero-bg" style="background-image: url('<%= item.mainImage %>')"></div>
  <div class="page-hero-overlay"></div>
  <div class="page-hero-content container">
    <nav class="crumbs" style="color: rgba(255,255,255,0.7)">
      <a href="<%= langPrefix %>/" style="color: rgba(255,255,255,0.7)"><%= lang === 'en' ? 'Home' : 'მთავარი' %></a>
      <span class="crumbs-sep">/</span>
      <a href="<%= langPrefix %>/gallery" style="color: rgba(255,255,255,0.7)"><%= lang === 'en' ? 'Gallery' : 'გალერეა' %></a>
      <span class="crumbs-sep">/</span>
      <span style="color: var(--white)"><%= l(item, 'title') %></span>
    </nav>
    <h1><%= l(item, 'title') %></h1>
    <p style="margin-top: var(--sp-3); color: rgba(255,255,255,0.85)"><%= item.date %></p>
  </div>
</section>

<% if (l(item, 'description')) { %>
<section class="section">
  <div class="container container-narrow">
    <p class="lead"><%= l(item, 'description') %></p>
  </div>
</section>
<% } %>

<% if (item.images && item.images.length) { %>
<section class="section">
  <div class="container">
    <div class="text-center" style="margin-bottom: var(--sp-8)">
      <p class="eyebrow" style="justify-content: center; display: inline-flex"><%= lang === 'en' ? 'Photos from this trip' : 'ფოტოები ამ მოგზაურობიდან' %></p>
      <h2><%= lang === 'en' ? 'The Journey in Pictures' : 'მოგზაურობა ფოტოებში' %></h2>
    </div>
    <div class="gallery-grid">
      <% item.images.forEach((img, idx) => { %>
        <div class="gallery-item" data-full="<%= img %>" data-title="<%= l(item, 'title') %>">
          <img src="<%= img %>" alt="<%= l(item, 'title') %>" loading="lazy">
        </div>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

<% if (reviews && reviews.length > 0) { %>
<section class="section section-alt">
  <div class="container">
    <div class="text-center" style="margin-bottom: var(--sp-8)">
      <p class="eyebrow" style="justify-content: center; display: inline-flex"><%= lang === 'en' ? 'From this adventure' : 'ამ თავგადასავლიდან' %></p>
      <h2><%= lang === 'en' ? 'What they said' : 'რას ამბობდნენ' %></h2>
    </div>
    <div class="grid grid-3">
      <% reviews.forEach(review => { %>
        <%- include('../partials/_review-card', { review, hikeName: null }) %>
      <% }); %>
    </div>
  </div>
</section>
<% } %>
