<section class="error-page">
  <div class="container text-center">
    <h1 class="error-code">404</h1>
    <h2 class="error-title"><%= t('page.not_found') %></h2>
    <p class="error-text"><%= t('page.not_found_text') %></p>
    <div class="error-actions">
      <a href="<%= langPrefix %>/" class="btn btn-primary"><%= t('page.back_home') %></a>
      <a href="<%= langPrefix %>/hikes" class="btn btn-secondary"><%= t('page.view_hikes') %></a>
    </div>
  </div>
</section>
