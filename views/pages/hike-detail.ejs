<!-- DETAIL HERO -->
<section class="detail-hero">
  <div class="detail-hero-bg" style="background-image: url('<%- escapeAttr(hike.heroImage) %>')"></div>
  <div class="detail-hero-overlay"></div>
  <div class="detail-hero-content container">
    <a href="<%= langPrefix %>/hikes" class="back-link">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      <%= t('hike.back') %>
    </a>
    <h1><%= l(hike, 'name') %></h1>
    <p class="detail-region"><%= l(hike, 'region') %>, <%= t('hike.georgia') %></p>
  </div>
</section>

<!-- QUICK INFO BAR -->
<section class="quick-info-bar">
  <div class="container">
    <div class="quick-info-grid">
      <% const dates = Array.isArray(hike.dates) ? hike.dates : (hike.date ? [hike.date] : []); %>
      <% if (dates.length) { %>
        <div class="quick-info-item">
          <span class="quick-info-label"><%= dates.length > 1 ? t('hike.dates') : t('hike.date') %></span>
          <span class="quick-info-value"><%= dates.map(d => new Date(d).toLocaleDateString(lang === 'en' ? 'en-US' : 'ka-GE', { year: 'numeric', month: 'long', day: 'numeric' })).join(', ') %></span>
        </div>
      <% } %>
      <div class="quick-info-item">
        <span class="quick-info-label"><%= t('hike.duration') %></span>
        <span class="quick-info-value"><%= l(hike, 'duration') %></span>
      </div>
      <div class="quick-info-item">
        <span class="quick-info-label"><%= t('hike.distance') %></span>
        <span class="quick-info-value"><%= hike.distance %></span>
      </div>
      <div class="quick-info-item">
        <span class="quick-info-label"><%= t('hike.difficulty') %></span>
        <span class="quick-info-value"><%= t('hike.difficulty.' + hike.difficulty) %></span>
      </div>
      <div class="quick-info-item">
        <span class="quick-info-label"><%= t('hike.elevation') %></span>
        <span class="quick-info-value"><%= hike.elevation %></span>
      </div>
      <div class="quick-info-item">
        <span class="quick-info-label"><%= t('hike.group_size') %></span>
        <span class="quick-info-value"><%= hike.groupSize %></span>
      </div>
      <div class="quick-info-item">
        <span class="quick-info-label"><%= t('hike.price') %></span>
        <span class="quick-info-value price">&#8382;<%= hike.price %></span>
      </div>
    </div>
  </div>
</section>

<!-- DETAIL CONTENT -->
<section class="section">
  <div class="container">
    <div class="detail-layout">
      <div class="detail-main">
        <h2 class="detail-section-title"><%= t('hike.about') %></h2>
        <p class="detail-description"><%= l(hike, 'description') %></p>

        <h2 class="detail-section-title"><%= t('hike.highlights_title') %></h2>
        <ul class="detail-list highlights-list">
          <% hike.highlights.forEach(item => { %>
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent-emerald)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              <%= item %>
            </li>
          <% }) %>
        </ul>

        <div class="detail-includes-grid">
          <div>
            <h2 class="detail-section-title"><%= t('hike.included_title') %></h2>
            <ul class="detail-list included-list">
              <% hike.included.forEach(item => { %>
                <li>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent-emerald)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                  <%= item %>
                </li>
              <% }) %>
            </ul>
          </div>
          <div>
            <h2 class="detail-section-title"><%= t('hike.not_included_title') %></h2>
            <ul class="detail-list not-included-list">
              <% hike.notIncluded.forEach(item => { %>
                <li>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  <%= item %>
                </li>
              <% }) %>
            </ul>
          </div>
        </div>
      </div>
      <aside class="detail-sidebar">
        <div class="booking-widget">
          <% if (typeof success !== 'undefined' && success) { %>
            <h3><%= t('reg.success_title') %></h3>
            <p><%= t('reg.success_text') %></p>
            <% if (hike.messengerLink || hike.whatsappLink) { %>
              <p style="margin-top: 1rem; font-weight: 600;"><%= t('reg.join_chat') %></p>
              <div style="display: flex; flex-direction: column; gap: 0.75rem; margin-top: 0.75rem;">
                <% if (hike.messengerLink) { %>
                  <a href="<%- escapeAttr(hike.messengerLink) %>" target="_blank" rel="noopener" class="btn btn-primary" style="width:100%;justify-content:center;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="margin-right:0.5rem;"><path d="M12 2C6.36 2 2 6.13 2 11.7c0 2.91 1.2 5.42 3.17 7.2V22l2.93-1.63c.84.23 1.72.35 2.63.35h.27c5.64 0 10-4.13 10-9.7S17.64 2 12 2zm1.07 12.95l-2.54-2.73L5.5 15l5.5-5.93 2.6 2.73L18.5 9l-5.43 5.95z"/></svg>
                    <%= t('reg.messenger') %>
                  </a>
                <% } %>
                <% if (hike.whatsappLink) { %>
                  <a href="<%- escapeAttr(hike.whatsappLink) %>" target="_blank" rel="noopener" class="btn btn-primary" style="width:100%;justify-content:center;background:var(--accent-emerald);">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="margin-right:0.5rem;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    <%= t('reg.whatsapp') %>
                  </a>
                <% } %>
              </div>
            <% } %>
          <% } else { %>
            <h3><%= t('reg.title') %></h3>
            <p class="widget-price"><strong>&#8382;<%= hike.price %></strong> <%= t('hike.per_person') %></p>
            <form action="<%= langPrefix %>/hikes/<%= hike.id %>/register" method="POST" novalidate>
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="hidden" name="hikeId" value="<%= hike.id %>">
              <div class="form-group" style="margin-bottom: 0.75rem;">
                <label class="form-label" for="reg-name"><%= t('reg.name_label') %></label>
                <input type="text" id="reg-name" name="name" class="form-input" required>
                <p class="form-error"><%= t('reg.name_error') %></p>
              </div>
              <div class="form-group" style="margin-bottom: 0.75rem;">
                <label class="form-label" for="reg-email"><%= t('reg.email_label') %></label>
                <input type="email" id="reg-email" name="email" class="form-input" required>
                <p class="form-error"><%= t('reg.email_error') %></p>
              </div>
              <div class="form-group" style="margin-bottom: 1rem;">
                <label class="form-label" for="reg-phone"><%= t('reg.phone_label') %></label>
                <input type="tel" id="reg-phone" name="phone" class="form-input" required>
                <p class="form-error"><%= t('reg.phone_error') %></p>
              </div>
              <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;"><%= t('reg.btn') %></button>
            </form>
            <a href="<%= langPrefix %>/contact" class="btn btn-secondary" style="width:100%;justify-content:center;margin-top:0.75rem;"><%= t('reg.ask_question') %></a>
          <% } %>
        </div>
      </aside>
    </div>
  </div>
</section>

<% if (hike.route && hike.route.coordinates && hike.route.coordinates.length) { %>
<section class="detail-section">
  <div class="container">
    <h2 class="detail-section-title"><%= t('map.title') %></h2>
    <div id="hike-trail-map" class="trail-map"></div>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        initTrailMap('hike-trail-map', <%- JSON.stringify(hike.route) %>);
      });
    </script>
  </div>
</section>
<% } %>

<!-- IMAGE GALLERY STRIP -->
<section class="section section-dark">
  <div class="container">
    <h2 class="section-title text-center" style="margin-bottom: 2rem;"><%- t('hike.photo_gallery') %></h2>
    <div class="detail-gallery-strip">
      <% hike.images.forEach((img, i) => { %>
        <div class="detail-gallery-img gallery-item" data-full="<%- escapeAttr(img) %>" data-title="<%= l(hike, 'name') %>" data-location="<%= l(hike, 'region') %>">
          <img src="<%- escapeAttr(img) %>" alt="<%= l(hike, 'name') %> - <%= i + 1 %>" loading="lazy">
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- REVIEWS FOR THIS HIKE -->
<% if (hikeReviews.length > 0) { %>
<section class="section">
  <div class="container">
    <h2 class="section-title text-center" style="margin-bottom: 2rem;"><%- t('hike.reviews_title') %></h2>
    <div class="review-grid">
      <% hikeReviews.forEach(review => { %>
        <%- include('../partials/_review-card', { review, hikeName: '' }) %>
      <% }) %>
    </div>
  </div>
</section>
<% } %>
