<section class="hike-hero">
  <div class="hike-hero-bg" style="background-image: url('<%- escapeAttr(hike.heroImage || hike.cardImage || (hike.images && hike.images[0]) || '/images/hikes-hero.jpeg') %>')"></div>
  <div class="hike-hero-content container">
    <nav class="crumbs" style="color: rgba(255,255,255,0.7);">
      <a href="<%= langPrefix %>/" style="color: rgba(255,255,255,0.7);"><%= lang === 'en' ? 'Home' : 'მთავარი' %></a>
      <span class="crumbs-sep">/</span>
      <a href="<%= langPrefix %>/hikes" style="color: rgba(255,255,255,0.7);"><%= lang === 'en' ? 'Hikes' : 'ლაშქრობა' %></a>
      <span class="crumbs-sep">/</span>
      <span style="color: var(--white);"><%= l(hike, 'name') %></span>
    </nav>
    <p class="eyebrow" style="color: var(--amber-300);"><%= l(hike, 'region') %></p>
    <h1><%= l(hike, 'name') %></h1>
    <div class="hero-meta">
      <% if (l(hike, 'duration')) { %>
      <span class="hero-meta-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <%= l(hike, 'duration') %>
      </span>
      <% } %>
      <% if (hike.distance) { %>
      <span class="hero-meta-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3h13v13"/><path d="M21 3L3 21"/></svg>
        <%= hike.distance %>
      </span>
      <% } %>
      <% if (hike.elevation) { %>
      <span class="hero-meta-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
        <%= lang === 'en' ? 'Elevation gain:' : 'ასვლა:' %> <%= hike.elevation %>
      </span>
      <% } %>
      <span class="hero-meta-item badge diff-<%= hike.difficulty || 'medium' %>" style="background: rgba(255,255,255,0.1); color: var(--white); border-color: rgba(255,255,255,0.2)">
        <%= lang === 'en'
              ? (hike.difficulty === 'easy' ? 'Easy' : hike.difficulty === 'hard' ? 'Advanced' : 'Moderate')
              : (hike.difficulty === 'easy' ? 'მარტივი' : hike.difficulty === 'hard' ? 'რთული' : 'საშუალო') %>
      </span>
    </div>
  </div>
</section>

<div class="container">
<% if (typeof success !== 'undefined' && success) { %>
  <div class="alert alert-success" style="margin-top: var(--sp-8)">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    <div>
      <strong><%= t('reg.success_title') || (lang === 'en' ? 'Registration received!' : 'რეგისტრაცია მიღებულია!') %></strong>
      <p style="margin: 4px 0 0"><%= t('reg.success_body') || (lang === 'en' ? 'We\'ll confirm by email within 24 hours.' : 'დადასტურებას გამოგიგზავნით 24 საათში.') %></p>
    </div>
  </div>
<% } %>

<% if (typeof errors !== 'undefined' && errors && errors.length) { %>
  <div class="alert alert-error" style="margin-top: var(--sp-8)">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
    <div>
      <strong><%= lang === 'en' ? 'Please fix the following:' : 'გთხოვთ, გაასწოროთ:' %></strong>
      <ul style="margin: 6px 0 0; padding-left: 20px"><% errors.forEach(e => { %><li><%= e.msg %></li><% }); %></ul>
    </div>
  </div>
<% } %>

<!-- Gallery strip -->
<% if (hike.images && hike.images.length) { %>
<section style="padding-top: var(--sp-8)">
  <div class="hike-gallery" data-gallery>
    <% hike.images.slice(0, 5).forEach((img, i) => { %>
      <a class="hike-gallery-item" href="<%= img %>" data-lightbox="hike" data-index="<%= i %>">
        <img src="<%= img %>" alt="<%= l(hike, 'name') %> — <%= i + 1 %>" loading="lazy">
      </a>
    <% }); %>
  </div>
</section>
<% } %>

<div class="hike-layout">
  <!-- Main column -->
  <div class="hike-main">

    <!-- Key features -->
    <div class="hike-features">
      <div class="hike-feature"><span><%= lang === 'en' ? 'Duration' : 'ხანგრძლივობა' %></span><b><%= l(hike, 'duration') || '—' %></b></div>
      <div class="hike-feature"><span><%= lang === 'en' ? 'Distance' : 'მანძილი' %></span><b><%= hike.distance || '—' %></b></div>
      <div class="hike-feature"><span><%= lang === 'en' ? 'Elevation' : 'ასვლა' %></span><b><%= hike.elevation || '—' %></b></div>
      <div class="hike-feature"><span><%= lang === 'en' ? 'Group size' : 'ჯგუფი' %></span><b><%= hike.groupSize || '—' %></b></div>
      <div class="hike-feature"><span><%= lang === 'en' ? 'Difficulty' : 'სირთულე' %></span><b><%= lang === 'en'
            ? (hike.difficulty === 'easy' ? 'Easy' : hike.difficulty === 'hard' ? 'Advanced' : 'Moderate')
            : (hike.difficulty === 'easy' ? 'მარტივი' : hike.difficulty === 'hard' ? 'რთული' : 'საშუალო') %></b></div>
      <div class="hike-feature"><span><%= lang === 'en' ? 'Region' : 'რეგიონი' %></span><b><%= l(hike, 'region') %></b></div>
    </div>

    <!-- Description -->
    <% if (l(hike, 'description')) { %>
    <h2><%= lang === 'en' ? 'About this hike' : 'ლაშქრობის შესახებ' %></h2>
    <p style="white-space: pre-line"><%= l(hike, 'description') %></p>
    <% } %>

    <!-- Highlights -->
    <% if (l(hike, 'highlights') && l(hike, 'highlights').length) { %>
    <h2><%= lang === 'en' ? 'Highlights' : 'ღირსშესანიშნაობები' %></h2>
    <ul class="checklist">
      <% l(hike, 'highlights').forEach(h => { %>
        <li><%= h %></li>
      <% }); %>
    </ul>
    <% } %>

    <!-- Included / Not included -->
    <% if ((l(hike, 'included') && l(hike, 'included').length) || (l(hike, 'notIncluded') && l(hike, 'notIncluded').length)) { %>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-8); margin-top: var(--sp-10)" class="included-grid">
      <% if (l(hike, 'included') && l(hike, 'included').length) { %>
        <div>
          <h2 style="margin-top: 0"><%= lang === 'en' ? 'What\'s included' : 'შედის ფასში' %></h2>
          <ul class="checklist">
            <% l(hike, 'included').forEach(i => { %><li><%= i %></li><% }); %>
          </ul>
        </div>
      <% } %>
      <% if (l(hike, 'notIncluded') && l(hike, 'notIncluded').length) { %>
        <div>
          <h2 style="margin-top: 0"><%= lang === 'en' ? 'Not included' : 'არ შედის' %></h2>
          <ul class="checklist not-included">
            <% l(hike, 'notIncluded').forEach(i => { %><li><%= i %></li><% }); %>
          </ul>
        </div>
      <% } %>
    </div>
    <% } %>

    <!-- Reviews -->
    <% if (hikeReviews && hikeReviews.length) { %>
    <h2><%= lang === 'en' ? 'What hikers say' : 'მოლაშქრეების მიმოხილვები' %></h2>
    <div class="grid grid-2">
      <% hikeReviews.slice(0, 4).forEach(review => { %>
        <%- include('../partials/_review-card', { review, hikeName: null }) %>
      <% }); %>
    </div>
    <% } %>

  </div>

  <!-- Booking sidebar -->
  <aside>
    <div class="booking-card">
      <% if (hike.price) { %>
      <div class="booking-card-price">
        <b>₾<%= hike.price %></b>
        <span><%= lang === 'en' ? '/ person' : '/ კაცი' %></span>
      </div>
      <% } %>

      <% const dates = Array.isArray(hike.dates) ? hike.dates : (hike.date ? [hike.date] : []); %>
      <div class="booking-meta">
        <% if (l(hike, 'duration')) { %>
        <div class="booking-meta-row"><span><%= lang === 'en' ? 'Duration' : 'ხანგრძლივობა' %></span><span><%= l(hike, 'duration') %></span></div>
        <% } %>
        <% if (hike.groupSize) { %>
        <div class="booking-meta-row"><span><%= lang === 'en' ? 'Group size' : 'ჯგუფის ზომა' %></span><span><%= hike.groupSize %></span></div>
        <% } %>
        <% if (dates.length) { %>
        <div class="booking-meta-row"><span><%= lang === 'en' ? 'Next dates' : 'მომდევნო თარიღები' %></span><span><%= dates.slice(0,2).map(d => new Date(d).toLocaleDateString(lang === 'en' ? 'en-US' : 'ka-GE', { day: 'numeric', month: 'short' })).join(', ') %></span></div>
        <% } %>
        <div class="booking-meta-row"><span><%= lang === 'en' ? 'Transfer' : 'ტრანსფერი' %></span><span style="color: var(--success)">✓ <%= lang === 'en' ? 'Included' : 'შედის' %></span></div>
      </div>

      <form action="<%= langPrefix %>/hikes/<%= hike.id %>/register" method="POST" novalidate>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="stack stack-sm">
          <div class="field">
            <label for="reg-name"><%= lang === 'en' ? 'Full name' : 'სახელი და გვარი' %></label>
            <input type="text" id="reg-name" name="name" class="input" required>
          </div>
          <div class="field">
            <label for="reg-email"><%= lang === 'en' ? 'Email' : 'ელ. ფოსტა' %></label>
            <input type="email" id="reg-email" name="email" class="input" required>
          </div>
          <div class="field">
            <label for="reg-phone"><%= lang === 'en' ? 'Phone' : 'ტელეფონი' %></label>
            <input type="tel" id="reg-phone" name="phone" class="input" required>
          </div>
          <% if (dates.length > 1) { %>
          <div class="field">
            <label for="reg-date"><%= lang === 'en' ? 'Preferred date' : 'სასურველი თარიღი' %></label>
            <select id="reg-date" name="date" class="select">
              <% dates.forEach(d => { %>
                <option value="<%= d %>"><%= new Date(d).toLocaleDateString(lang === 'en' ? 'en-US' : 'ka-GE', { year: 'numeric', month: 'long', day: 'numeric' }) %></option>
              <% }); %>
            </select>
          </div>
          <% } %>
        </div>

        <button type="submit" class="btn btn-primary btn-block btn-lg" style="margin-top: var(--sp-5)">
          <%= lang === 'en' ? 'Book This Adventure' : 'დაჯავშნე' %>
        </button>
        <p class="form-note" style="text-align: center; margin-top: var(--sp-3)"><%= lang === 'en' ? 'No upfront payment · Confirmation in 24h · Free cancellation 7 days prior' : 'წინასწარი გადახდა არ საჭიროა · დადასტურება 24 საათში' %></p>
      </form>

      <% if (hike.whatsappLink) { %>
      <hr class="divider divider-tight">
      <a href="<%= hike.whatsappLink %>" target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-block" style="border-color: #25d366; color: #0e8d50">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.6 6.32A7.85 7.85 0 0 0 12.05 4a7.94 7.94 0 0 0-6.88 11.89L4 20l4.22-1.1a7.93 7.93 0 0 0 3.83.98h.01c4.37 0 7.94-3.56 7.94-7.94a7.9 7.9 0 0 0-2.4-5.62Zm-5.55 12.22h-.01a6.6 6.6 0 0 1-3.36-.92l-.24-.14-2.5.65.67-2.44-.16-.25a6.58 6.58 0 1 1 12.2-3.51 6.6 6.6 0 0 1-6.6 6.61Zm3.62-4.95c-.2-.1-1.17-.58-1.35-.64-.18-.07-.31-.1-.45.1-.13.2-.51.64-.63.77-.11.13-.23.15-.43.05-.2-.1-.84-.31-1.6-.99-.59-.52-.99-1.17-1.1-1.37-.12-.2-.01-.31.09-.41.09-.09.2-.23.3-.35.1-.11.13-.2.2-.33.07-.14.03-.25-.02-.35-.05-.1-.45-1.08-.62-1.48-.16-.39-.33-.34-.45-.34l-.39-.01c-.13 0-.35.05-.53.25-.18.2-.69.68-.69 1.65 0 .97.71 1.92.8 2.05.1.13 1.39 2.12 3.37 2.97.47.2.84.32 1.13.41.47.15.9.13 1.24.08.38-.06 1.17-.48 1.34-.94.16-.46.16-.85.12-.94-.05-.08-.18-.13-.38-.23Z"/></svg>
        <%= lang === 'en' ? 'Chat on WhatsApp' : 'WhatsApp-ზე დაწერა' %>
      </a>
      <% } %>
    </div>
  </aside>
</div>

</div><!-- /container -->

<script>
  // Simple lightbox wiring for the gallery strip
  document.querySelectorAll('[data-lightbox="hike"]').forEach((a, i, arr) => {
    a.addEventListener('click', function(e) {
      e.preventDefault();
      const lb = document.getElementById('lightbox');
      const img = document.getElementById('lightbox-img');
      const title = document.getElementById('lightbox-title');
      img.src = this.href;
      title.textContent = this.querySelector('img')?.alt || '';
      lb.classList.add('is-open');
    });
  });
  document.querySelector('.lightbox-close')?.addEventListener('click', () => document.getElementById('lightbox').classList.remove('is-open'));
  document.getElementById('lightbox')?.addEventListener('click', e => { if (e.target.id === 'lightbox') e.currentTarget.classList.remove('is-open'); });
</script>

<style>
  @media (max-width: 760px) {
    .included-grid { grid-template-columns: 1fr !important; }
  }
</style>
