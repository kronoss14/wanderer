<section class="page-hero" style="min-height: 280px">
  <div class="page-hero-bg" style="background-image: url('/images/hikes-hero.jpeg'); background-position: center 65%"></div>
  <div class="page-hero-overlay"></div>
  <div class="page-hero-content container">
    <p class="eyebrow"><%= lang === 'en' ? 'Interactive map' : 'ინტერაქტიული რუკა' %></p>
    <h1><%= lang === 'en' ? 'Explore Georgia on the Map' : 'აღმოაჩინე საქართველო რუკაზე' %></h1>
    <p><%= lang === 'en' ? 'Every hiking route, viewpoint, fortress, monastery and hidden gem we\'ve tracked — in one place.' : 'ყველა ბილიკი, ხედი, ციხე-სიმაგრე და მონასტერი, რომელიც გვინახავს — ერთ რუკაზე.' %></p>
  </div>
</section>

<section class="section">
  <div class="container">

    <div class="map-toolbar">
      <div class="map-search-wrap">
        <svg class="map-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" id="map-search" class="map-search" placeholder="<%= lang === 'en' ? 'Search Kazbegi, Tusheti, Svaneti…' : 'ძებნა…' %>" autocomplete="off">
        <div id="map-search-results" class="map-search-results"></div>
      </div>
      <div class="map-filters">
        <button class="map-filter active" data-category="all"><%= lang === 'en' ? 'All' : 'ყველა' %></button>
        <button class="map-filter" data-category="hiking"><%= lang === 'en' ? 'Hiking' : 'ლაშქრობა' %></button>
        <button class="map-filter" data-category="sightseeing"><%= lang === 'en' ? 'Sightseeing' : 'ღირსშესანიშნაობები' %></button>
        <button class="map-filter" data-category="monastery"><%= lang === 'en' ? 'Monastery' : 'მონასტერი' %></button>
        <button class="map-filter" data-category="fortress"><%= lang === 'en' ? 'Fortress' : 'ციხე' %></button>
        <button class="map-filter" data-category="canyon"><%= lang === 'en' ? 'Canyon' : 'კანიონი' %></button>
        <button class="map-filter" data-category="waterfall"><%= lang === 'en' ? 'Waterfall' : 'ჩანჩქერი' %></button>
        <button class="map-filter" data-category="cave"><%= lang === 'en' ? 'Cave' : 'გამოქვაბული' %></button>
        <button class="map-filter" data-category="volcano"><%= lang === 'en' ? 'Volcano' : 'ვულკანი' %></button>
        <button class="map-filter" data-category="nature"><%= lang === 'en' ? 'Nature' : 'ბუნება' %></button>
      </div>
    </div>

    <button class="map-legend-toggle" id="legend-toggle">
      <%= lang === 'en' ? 'Show legend' : 'ლეგენდა' %>
    </button>
    <div class="map-legend" id="map-legend">
      <span class="map-legend-item"><span class="legend-icon">🥾</span> <%= lang === 'en' ? 'Hiking' : 'ლაშქრობა' %></span>
      <span class="map-legend-item"><span class="legend-icon">📍</span> <%= lang === 'en' ? 'Sightseeing' : 'ღირსშესანიშნაობა' %></span>
      <span class="map-legend-item"><span class="legend-icon">⛪</span> <%= lang === 'en' ? 'Monastery' : 'მონასტერი' %></span>
      <span class="map-legend-item"><span class="legend-icon">🏰</span> <%= lang === 'en' ? 'Fortress' : 'ციხე' %></span>
      <span class="map-legend-item"><span class="legend-icon">🏞️</span> <%= lang === 'en' ? 'Canyon' : 'კანიონი' %></span>
      <span class="map-legend-item"><span class="legend-icon">💧</span> <%= lang === 'en' ? 'Waterfall' : 'ჩანჩქერი' %></span>
      <span class="map-legend-item"><span class="legend-icon">🕳️</span> <%= lang === 'en' ? 'Cave' : 'გამოქვაბული' %></span>
      <span class="map-legend-item"><span class="legend-icon">🌋</span> <%= lang === 'en' ? 'Volcano' : 'ვულკანი' %></span>
      <span class="map-legend-item"><span class="legend-icon">🌿</span> <%= lang === 'en' ? 'Nature' : 'ბუნება' %></span>
    </div>

    <div style="position: relative">
      <div id="overview-map" style="height: 72vh; min-height: 560px; border-radius: var(--r-lg); overflow: hidden; border: 1px solid var(--border); background: var(--stone-100);"></div>
      <div id="map-info-panel" class="map-info-panel" style="display: none; position: absolute; bottom: var(--sp-5); right: var(--sp-5); width: 340px; max-width: calc(100% - var(--sp-10)); background: var(--white); border-radius: var(--r-lg); padding: var(--sp-5); box-shadow: var(--shadow-xl); z-index: 500;">
        <div class="info-panel-drag-handle" style="display: none"></div>
        <button class="info-panel-close" style="position: absolute; top: 8px; right: 10px; font-size: 22px; color: var(--text-muted); width: 32px; height: 32px; border-radius: var(--r-full)">&times;</button>
        <div class="info-panel-header" style="display: flex; gap: var(--sp-3); align-items: center; margin-bottom: var(--sp-3)">
          <span class="info-panel-emoji" style="font-size: 28px"></span>
          <div class="info-panel-header-text">
            <h3 class="info-panel-name" style="margin: 0; font-size: var(--text-lg)"></h3>
            <span class="info-panel-category text-muted" style="font-size: var(--text-xs)"></span>
          </div>
        </div>
        <div class="info-panel-body" style="font-size: var(--text-sm); color: var(--text)"></div>
      </div>
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', function() {
        var hikes = <%- JSON.stringify(hikes.map(function(h) {
          return {
            id: h.id,
            displayName: l(h, 'name'),
            route: h.route || {}
          };
        })) %>;
        if (typeof initOverviewMap === 'function') {
          initOverviewMap('overview-map', hikes, '<%= langPrefix %>');
        }

        var legendToggle = document.getElementById('legend-toggle');
        var legend = document.getElementById('map-legend');
        if (legendToggle && legend) {
          legendToggle.addEventListener('click', function() {
            legend.classList.toggle('is-open');
          });
        }
      });
    </script>
  </div>
</section>
