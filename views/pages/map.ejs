<section class="page-hero" style="min-height: 200px">
  <div class="page-hero-bg" style="background-image: url('/images/hikes-hero.jpeg'); background-position: center 65%"></div>
  <div class="page-hero-overlay" style="background: linear-gradient(180deg, rgba(13,13,13,0.7) 0%, rgba(13,13,13,0.5) 100%)"></div>
  <div class="page-hero-content container">
    <h1><%= t('map.title') %></h1>
    <p><%= t('map.subtitle') %></p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="map-toolbar">
      <div class="map-search-wrap">
        <svg class="map-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" id="map-search" class="map-search" placeholder="<%= t('map.search_placeholder') %>" autocomplete="off">
        <div id="map-search-results" class="map-search-results"></div>
      </div>
      <div class="map-filters">
        <button class="map-filter active" data-category="all"><%= t('map.filter_all') %></button>
        <button class="map-filter" data-category="hiking"><%= t('map.filter_hiking') %></button>
        <button class="map-filter" data-category="sightseeing"><%= t('map.filter_sightseeing') %></button>
        <button class="map-filter" data-category="monastery"><%= t('map.filter_monastery') %></button>
        <button class="map-filter" data-category="fortress"><%= t('map.filter_fortress') %></button>
        <button class="map-filter" data-category="canyon"><%= t('map.filter_canyon') %></button>
        <button class="map-filter" data-category="waterfall"><%= t('map.filter_waterfall') %></button>
        <button class="map-filter" data-category="cave"><%= t('map.filter_cave') %></button>
        <button class="map-filter" data-category="stone"><%= t('map.filter_stone') %></button>
        <button class="map-filter" data-category="volcano"><%= t('map.filter_volcano') %></button>
        <button class="map-filter" data-category="nature"><%= t('map.filter_nature') %></button>
      </div>
    </div>
    <button class="map-legend-toggle" id="legend-toggle"><%= t('map.legend') %></button>
    <div class="map-legend" id="map-legend">
      <span class="map-legend-item"><span class="legend-icon">🥾</span> <%= t('map.filter_hiking') %></span>
      <span class="map-legend-item"><span class="legend-icon">📍</span> <%= t('map.filter_sightseeing') %></span>
      <span class="map-legend-item"><span class="legend-icon">⛪</span> <%= t('map.filter_monastery') %></span>
      <span class="map-legend-item"><span class="legend-icon">🏰</span> <%= t('map.filter_fortress') %></span>
      <span class="map-legend-item"><span class="legend-icon">🏞️</span> <%= t('map.filter_canyon') %></span>
      <span class="map-legend-item"><span class="legend-icon">💧</span> <%= t('map.filter_waterfall') %></span>
      <span class="map-legend-item"><span class="legend-icon">🕳️</span> <%= t('map.filter_cave') %></span>
      <span class="map-legend-item"><span class="legend-icon">🪨</span> <%= t('map.filter_stone') %></span>
      <span class="map-legend-item"><span class="legend-icon">🌋</span> <%= t('map.filter_volcano') %></span>
      <span class="map-legend-item"><span class="legend-icon">🌿</span> <%= t('map.filter_nature') %></span>
    </div>
    <div class="map-container-wrap">
      <div id="overview-map" class="overview-map"></div>
      <div id="map-info-panel" class="map-info-panel">
        <div class="info-panel-drag-handle"></div>
        <button class="info-panel-close">&times;</button>
        <div class="info-panel-header">
          <span class="info-panel-emoji"></span>
          <div class="info-panel-header-text">
            <h3 class="info-panel-name"></h3>
            <span class="info-panel-category"></span>
          </div>
        </div>
        <div class="info-panel-body"></div>
      </div>
    </div>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        var hikes = <%- JSON.stringify(hikes.map(function(h) {
          return {
            id: h.id,
            displayName: l(h, 'name'),
            route: h.route || {}
          };
        })) %>;
        initOverviewMap('overview-map', hikes, '<%= langPrefix %>');

        // Legend toggle for mobile
        var legendToggle = document.getElementById('legend-toggle');
        var legend = document.getElementById('map-legend');
        if (legendToggle && legend) {
          legendToggle.addEventListener('click', function() {
            legend.classList.toggle('legend-open');
            legendToggle.classList.toggle('active');
          });
        }
      });
    </script>
  </div>
</section>
