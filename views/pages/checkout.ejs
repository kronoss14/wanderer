<section class="section">
  <div class="container">
    <h1 style="margin-bottom:2rem;"><%= t('checkout.title') %></h1>

    <% if (typeof errors !== 'undefined' && errors && errors.length) { %>
      <div class="flash flash-error" style="background:rgba(220,53,69,0.1);border:1px solid rgba(220,53,69,0.3);border-radius:var(--radius);padding:1rem;margin-bottom:1.5rem;">
        <ul style="margin:0;padding-left:1.5rem;color:#dc3545;">
          <% errors.forEach(e => { %><li><%= e.msg %></li><% }) %>
        </ul>
      </div>
    <% } %>

    <div id="checkout-empty" style="display:none;">
      <p class="text-center" style="color:var(--text-secondary);padding:3rem 0;"><%= t('cart.empty') %></p>
      <div class="text-center">
        <a href="<%= langPrefix %>/shop" class="btn btn-primary"><%= t('cart.continue_shopping') %></a>
      </div>
    </div>

    <form method="POST" action="<%= langPrefix %>/cart/checkout" id="checkout-form" style="display:none;" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="items" id="checkout-items" value="">

      <div class="checkout-layout">
        <div class="checkout-form-section">
          <h2 style="font-size:1.2rem;margin-bottom:1.25rem;"><%= t('checkout.contact_info') %></h2>

          <div class="form-group" style="margin-bottom:1rem;">
            <label class="form-label" for="checkout-name"><%= t('checkout.name') %> *</label>
            <input type="text" id="checkout-name" name="name" class="form-input" required value="<%= typeof formData !== 'undefined' && formData ? formData.name || '' : '' %>">
          </div>

          <div class="form-group" style="margin-bottom:1rem;">
            <label class="form-label" for="checkout-email"><%= t('checkout.email') %> *</label>
            <input type="email" id="checkout-email" name="email" class="form-input" required value="<%= typeof formData !== 'undefined' && formData ? formData.email || '' : '' %>">
          </div>

          <div class="form-group" style="margin-bottom:1rem;">
            <label class="form-label" for="checkout-phone"><%= t('checkout.phone') %> *</label>
            <input type="tel" id="checkout-phone" name="phone" class="form-input" required value="<%= typeof formData !== 'undefined' && formData ? formData.phone || '' : '' %>">
          </div>

          <div class="form-group" style="margin-bottom:1.5rem;">
            <label class="form-label" for="checkout-address"><%= t('checkout.address') %></label>
            <textarea id="checkout-address" name="address" class="form-input" rows="3"><%= typeof formData !== 'undefined' && formData ? formData.address || '' : '' %></textarea>
          </div>

          <h2 style="font-size:1.2rem;margin-bottom:1.25rem;"><%= t('checkout.payment_method') %></h2>

          <div class="payment-options">
            <label class="payment-option">
              <input type="radio" name="paymentMethod" value="bank_transfer" checked>
              <div class="payment-option-body">
                <strong><%= t('checkout.bank_transfer') %></strong>
                <span><%= t('checkout.bank_transfer_desc') %></span>
              </div>
            </label>
            <label class="payment-option">
              <input type="radio" name="paymentMethod" value="on_delivery">
              <div class="payment-option-body">
                <strong><%= t('checkout.on_delivery') %></strong>
                <span><%= t('checkout.on_delivery_desc') %></span>
              </div>
            </label>
            <label class="payment-option">
              <input type="radio" name="paymentMethod" value="on_pickup">
              <div class="payment-option-body">
                <strong><%= t('checkout.on_pickup') %></strong>
                <span><%= t('checkout.on_pickup_desc') %></span>
              </div>
            </label>
          </div>
        </div>

        <div class="checkout-summary">
          <h2 style="font-size:1.2rem;margin-bottom:1.25rem;"><%= t('checkout.order_summary') %></h2>
          <div id="checkout-summary-items"></div>
          <div class="checkout-total">
            <strong><%= t('cart.total') %></strong>
            <strong id="checkout-total">&#8382;0</strong>
          </div>
          <div class="terms-accept" style="margin-top:1.25rem;">
            <label style="display:flex;gap:0.6rem;align-items:flex-start;cursor:pointer;font-size:0.85rem;color:var(--text-secondary);line-height:1.5;">
              <input type="checkbox" id="accept-terms" required style="margin-top:0.25rem;accent-color:var(--accent-orange);flex-shrink:0;">
              <span><%- t('checkout.terms_text') %></span>
            </label>
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:1rem;" id="place-order-btn">
            <%= t('checkout.place_order') %>
          </button>
        </div>
      </div>
    </form>
  </div>
</section>

<!-- Terms & Conditions Modal -->
<dialog id="terms-modal">
  <div class="terms-modal-inner">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;">
      <h2 style="font-size:1.3rem;"><%= t('terms.title') %></h2>
      <button class="terms-close-btn" aria-label="Close">&times;</button>
    </div>

    <div style="color:var(--text-secondary);font-size:0.9rem;line-height:1.8;">
      <h3 style="color:var(--text-primary);font-size:1rem;margin:1.25rem 0 0.5rem;"><%= t('terms.general_title') %></h3>
      <p><%= t('terms.general_text') %></p>

      <h3 style="color:var(--text-primary);font-size:1rem;margin:1.25rem 0 0.5rem;"><%= t('terms.payment_title') %></h3>
      <p><%= t('terms.payment_text') %></p>

      <h3 style="color:var(--text-primary);font-size:1rem;margin:1.25rem 0 0.5rem;"><%= t('terms.delivery_title') %></h3>
      <p><%= t('terms.delivery_text') %></p>

      <h3 style="color:var(--text-primary);font-size:1rem;margin:1.25rem 0 0.5rem;"><%= t('terms.returns_title') %></h3>
      <p><%= t('terms.returns_text') %></p>

      <h3 style="color:var(--text-primary);font-size:1rem;margin:1.25rem 0 0.5rem;"><%= t('terms.privacy_title') %></h3>
      <p><%= t('terms.privacy_text') %></p>
    </div>

    <button class="btn btn-primary terms-close-btn" style="width:100%;justify-content:center;margin-top:1.5rem;"><%= t('terms.close') %></button>
  </div>
</dialog>

<style>
  #terms-modal { max-width:650px;width:90vw;max-height:80vh;border-radius:var(--radius-lg);border:1px solid var(--border-color);background:var(--bg-card);color:var(--text-primary);padding:0; }
  #terms-modal::backdrop { background:rgba(0,0,0,0.7); }
  .terms-modal-inner { padding:2rem;overflow-y:auto;max-height:80vh; }
  .terms-close-btn { background:none;border:none;color:var(--text-muted);font-size:1.5rem;cursor:pointer;line-height:1; }
  .terms-link { color:var(--accent-orange) !important;text-decoration:underline !important; }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var modal = document.getElementById('terms-modal');
    if (!modal) return;

    // Open modal when terms link is clicked
    document.addEventListener('click', function(e) {
      if (e.target.classList.contains('terms-link')) {
        e.preventDefault();
        modal.showModal();
      }
    });

    // Close modal buttons
    modal.querySelectorAll('.terms-close-btn').forEach(function(btn) {
      btn.addEventListener('click', function() { modal.close(); });
    });

    // Close on backdrop click
    modal.addEventListener('click', function(e) {
      if (e.target === modal) modal.close();
    });
  });
</script>
