<!-- PAGE HERO -->
<section class="page-hero">
  <div class="page-hero-bg" style="background-image: url('/images/adventures-hero.jpeg'); background-position: center 70%"></div>
  <div class="page-hero-overlay"></div>
  <div class="page-hero-content container">
    <h1><%- t('gallery.title') %></h1>
    <p><%= t('gallery.subtitle') %></p>
  </div>
</section>

<!-- ADVENTURES GRID -->
<section class="section">
  <div class="container">
    <% if (gallery.length) { %>
      <div class="adventures-grid">
        <% gallery.forEach(item => { %>
          <a href="<%= langPrefix %>/gallery/<%= item.id %>" class="adventure-card">
            <div class="adventure-card-img">
              <img src="<%= item.mainImage %>" alt="<%= l(item, 'title') %>" loading="lazy">
            </div>
            <div class="adventure-card-overlay">
              <h3><%= l(item, 'title') %></h3>
              <span class="adventure-card-date"><%= item.date %></span>
            </div>
          </a>
        <% }) %>
      </div>
    <% } else { %>
      <p style="text-align:center;color:var(--text-muted);padding:3rem 0;"><%= t('gallery.empty') %></p>
    <% } %>
  </div>
</section>
