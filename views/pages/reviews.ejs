<section class="page-hero">
  <div class="page-hero-bg" style="background-image: url('/images/reviews-hero.jpeg'); background-position: center 80%"></div>
  <div class="page-hero-overlay"></div>
  <div class="page-hero-content container">
    <p class="eyebrow"><%= lang === 'en' ? 'Honest reviews' : 'გულწრფელი მიმოხილვები' %></p>
    <h1><%= lang === 'en' ? 'What Our Hikers Say' : 'რას ამბობენ ჩვენი მოლაშქრეები' %></h1>
    <p><%= lang === 'en' ? 'Real feedback from travelers who walked our trails. Good and critical — we publish it all.' : 'ნამდვილი შეფასებები, კარგიც და კრიტიკულიც.' %></p>
  </div>
</section>

<section class="section">
  <div class="container">

    <div class="card" style="padding: var(--sp-8); display: grid; grid-template-columns: auto 1fr; gap: var(--sp-10); align-items: center; margin-bottom: var(--sp-10)" id="rating-stats">
      <div class="text-center">
        <div style="font-family: var(--font-display); font-size: 64px; font-weight: 700; color: var(--forest-800); line-height: 1"><%= avgRating ? avgRating.toFixed(1) : '5.0' %></div>
        <div class="rating" style="margin-top: var(--sp-2); justify-content: center">
          <% for (let i = 0; i < 5; i++) { %>
            <% if (i < Math.round(avgRating || 5)) { %>
              <svg viewBox="0 0 24 24" width="18" height="18"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <% } else { %>
              <svg viewBox="0 0 24 24" width="18" height="18" class="rating-empty"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <% } %>
          <% } %>
        </div>
        <p class="text-muted" style="font-size: var(--text-sm); margin-top: var(--sp-2)"><%= reviews.length %> <%= lang === 'en' ? 'reviews' : 'მიმოხილვა' %></p>
      </div>
      <div class="stack stack-sm">
        <% for (let stars = 5; stars >= 1; stars--) { %>
          <% const count = reviews.filter(r => r.rating === stars).length; %>
          <% const pct = reviews.length ? (count / reviews.length * 100) : 0; %>
          <div style="display: grid; grid-template-columns: 40px 1fr 40px; gap: var(--sp-3); align-items: center; font-size: var(--text-sm)">
            <span><%= stars %> ★</span>
            <div style="height: 8px; background: var(--stone-100); border-radius: var(--r-full); overflow: hidden">
              <div style="height: 100%; width: <%= pct %>%; background: var(--amber-500); border-radius: var(--r-full);"></div>
            </div>
            <span class="text-muted" style="text-align: right"><%= count %></span>
          </div>
        <% } %>
      </div>
    </div>

    <% if (reviews.length) { %>
      <div class="grid grid-3">
        <% reviews.forEach(review => { %>
          <% const hike = hikes.find(h => h.id === review.hikeId); %>
          <%- include('../partials/_review-card', { review, hikeName: hike ? l(hike, 'name') : null }) %>
        <% }); %>
      </div>
    <% } else { %>
      <div class="alert alert-info" style="max-width: 560px; margin: 0 auto"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/></svg><div><%= lang === 'en' ? 'No reviews yet — be the first to share your experience.' : 'მიმოხილვები ჯერ არ არის.' %></div></div>
    <% } %>

  </div>
</section>

<section class="section section-alt">
  <div class="container container-narrow">

    <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert-success" style="margin-bottom: var(--sp-6)">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <div><strong><%= lang === 'en' ? 'Thanks for your review!' : 'გმადლობთ მიმოხილვისთვის!' %></strong><p style="margin: 4px 0 0"><%= lang === 'en' ? 'It will appear once our team approves it.' : 'გამოჩნდება მოდერაციის შემდეგ.' %></p></div>
      </div>
    <% } %>

    <% if (typeof errors !== 'undefined' && errors && errors.length) { %>
      <div class="alert alert-error" style="margin-bottom: var(--sp-6)">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/></svg>
        <ul style="margin:0;padding-left:20px"><% errors.forEach(e => { %><li><%= e.msg %></li><% }); %></ul>
      </div>
    <% } %>

    <div class="text-center" style="margin-bottom: var(--sp-8)">
      <p class="eyebrow" style="justify-content: center; display: inline-flex"><%= lang === 'en' ? 'Share your adventure' : 'გაიზიარე შენი თავგადასავალი' %></p>
      <h2><%= lang === 'en' ? 'Write a Review' : 'დაწერე მიმოხილვა' %></h2>
    </div>

    <div class="card" style="padding: var(--sp-8); display: block">
      <form action="<%= langPrefix %>/reviews" method="POST" class="stack stack-sm" id="review-form" novalidate>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-4)" class="fields-row">
          <div class="field"><label for="review-name"><%= lang === 'en' ? 'Your name' : 'სახელი' %></label><input type="text" id="review-name" name="name" class="input" required></div>
          <div class="field"><label for="review-email"><%= lang === 'en' ? 'Email' : 'ელ. ფოსტა' %></label><input type="email" id="review-email" name="email" class="input" required></div>
        </div>
        <div class="field">
          <label><%= lang === 'en' ? 'Rating' : 'შეფასება' %></label>
          <input type="hidden" name="rating" id="review-rating" required>
          <div id="star-picker" style="display: inline-flex; gap: 4px; cursor: pointer">
            <% for (let i = 1; i <= 5; i++) { %>
              <svg data-value="<%= i %>" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--stone-400)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <% } %>
          </div>
        </div>
        <div class="field">
          <label for="review-hike"><%= lang === 'en' ? 'Which hike? (optional)' : 'რომელი ლაშქრობა? (არასავალდ.)' %></label>
          <select id="review-hike" name="hikeId" class="select">
            <option value=""><%= lang === 'en' ? '— Any hike —' : '— ნებისმიერი —' %></option>
            <% hikes.forEach(hike => { %>
              <option value="<%= hike.id %>"><%= l(hike, 'name') %></option>
            <% }); %>
          </select>
        </div>
        <div class="field">
          <label for="review-text"><%= lang === 'en' ? 'Your review' : 'თქვენი მიმოხილვა' %></label>
          <textarea id="review-text" name="text" class="textarea" rows="6" required></textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-lg"><%= lang === 'en' ? 'Submit review' : 'გაგზავნა' %></button>
      </form>
    </div>
  </div>
</section>

<script>
(function() {
  var picker = document.getElementById('star-picker');
  var input = document.getElementById('review-rating');
  if (!picker || !input) return;
  var stars = picker.querySelectorAll('svg');
  var selected = 0;
  function highlight(n) {
    stars.forEach(function(s, i) {
      s.setAttribute('fill', i < n ? '#d4a574' : 'none');
      s.setAttribute('stroke', i < n ? '#c98a35' : 'var(--stone-400)');
    });
  }
  stars.forEach(function(star) {
    star.addEventListener('click', function() {
      selected = parseInt(this.getAttribute('data-value'));
      input.value = selected;
      highlight(selected);
    });
    star.addEventListener('mouseenter', function() {
      highlight(parseInt(this.getAttribute('data-value')));
    });
  });
  picker.addEventListener('mouseleave', function() { highlight(selected); });
})();
</script>

<style>
  @media (max-width: 560px) {
    #rating-stats { grid-template-columns: 1fr !important; text-align: center; }
    .fields-row { grid-template-columns: 1fr !important; }
  }
</style>
