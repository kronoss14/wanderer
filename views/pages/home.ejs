<!-- HERO -->
<section class="hero">
  <div class="hero-bg" style="background-image: url('/images/hero-home.jpeg')"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content container">
    <p class="hero-pre"><%= t('hero.pre') %></p>
    <h1 class="hero-title"><%- t('hero.title') %></h1>
    <p class="hero-sub"><%= t('hero.sub') %></p>
    <div class="hero-actions">
      <a href="<%= langPrefix %>/hikes" class="btn btn-primary"><%= t('hero.btn_view') %></a>
      <a href="<%= langPrefix %>/gallery" class="btn btn-secondary"><%= t('hero.btn_adventures') %></a>
    </div>
  </div>
  <div class="hero-scroll">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="7 13 12 18 17 13"/><polyline points="7 6 12 11 17 6"/></svg>
  </div>
</section>

<!-- FEATURED HIKES -->
<section class="section">
  <div class="container">
    <div class="text-center" style="margin-bottom: 3rem;">
      <h2 class="section-title"><%- t('home.featured_title') %></h2>
      <p class="section-subtitle centered"><%= t('home.featured_sub') %></p>
    </div>
    <div class="hike-grid">
      <% featured.forEach(hike => { %>
        <%- include('../partials/_hike-card', { hike }) %>
      <% }) %>
    </div>
    <div class="text-center" style="margin-top: 2.5rem;">
      <a href="<%= langPrefix %>/hikes" class="btn btn-secondary"><%= t('home.view_all_hikes') %></a>
    </div>
  </div>
</section>

<!-- WHY WANDERER -->
<section class="section section-dark">
  <div class="container">
    <div class="text-center" style="margin-bottom: 3rem;">
      <h2 class="section-title"><%- t('home.why_title') %></h2>
      <p class="section-subtitle centered"><%= t('home.why_sub') %></p>
    </div>
    <div class="why-grid">
      <div class="why-card">
        <div class="why-icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--accent-orange)" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3><%= t('home.why_safety_title') %></h3>
        <p><%= t('home.why_safety_text') %></p>
      </div>
      <div class="why-card">
        <div class="why-icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--accent-orange)" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
        </div>
        <h3><%= t('home.why_local_title') %></h3>
        <p><%= t('home.why_local_text') %></p>
      </div>
      <div class="why-card">
        <div class="why-icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--accent-orange)" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
        </div>
        <h3><%= t('home.why_included_title') %></h3>
        <p><%= t('home.why_included_text') %></p>
      </div>
    </div>
  </div>
</section>

<!-- TESTIMONIAL STRIP -->
<section class="section testimonial-strip">
  <div class="container">
    <div class="text-center" style="margin-bottom: 3rem;">
      <h2 class="section-title"><%- t('home.testimonials_title') %></h2>
    </div>
    <div class="testimonial-grid">
      <% topReviews.forEach(review => { %>
        <% const hike = hikes.find(h => h.id === review.hikeId); %>
        <%- include('../partials/_review-card', { review, hikeName: hike ? l(hike, 'name') : '' }) %>
      <% }) %>
    </div>
    <div class="text-center" style="margin-top: 2.5rem;">
      <a href="<%= langPrefix %>/reviews" class="btn btn-secondary"><%= t('home.view_all_reviews') %></a>
    </div>
  </div>
</section>

<!-- CTA BANNER -->
<section class="cta-banner">
  <div class="cta-bg" style="background-image: url('https://picsum.photos/seed/wanderer-cta/1920/600')"></div>
  <div class="cta-overlay"></div>
  <div class="cta-content container">
    <h2><%= t('home.cta_title') %></h2>
    <p><%= t('home.cta_text') %></p>
    <a href="<%= langPrefix %>/contact" class="btn btn-primary"><%= t('home.cta_btn') %></a>
  </div>
</section>
