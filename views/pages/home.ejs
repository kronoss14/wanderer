<!-- HERO -->
<section class="hero">
  <div class="hero-bg" style="background-image: url('https://picsum.photos/seed/wanderer-hero/1920/1080')"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content container">
    <p class="hero-pre">Discover Georgia's Caucasus Mountains</p>
    <h1 class="hero-title">Wander Beyond<br>the Ordinary</h1>
    <p class="hero-sub">Expert-guided hikes, treks, and cultural tours through one of the world's most breathtaking mountain landscapes.</p>
    <div class="hero-actions">
      <a href="/hikes" class="btn btn-primary">Explore Hikes</a>
      <a href="/booking" class="btn btn-secondary">Book Now</a>
    </div>
  </div>
  <div class="hero-scroll">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="7 13 12 18 17 13"/><polyline points="7 6 12 11 17 6"/></svg>
  </div>
</section>

<!-- FEATURED HIKES -->
<section class="section">
  <div class="container">
    <div class="text-center" style="margin-bottom: 3rem;">
      <h2 class="section-title">Featured <span class="text-accent">Adventures</span></h2>
      <p class="section-subtitle centered">From dramatic day hikes to multi-day wilderness treks, discover our most popular Georgian adventures.</p>
    </div>
    <div class="hike-grid">
      <% featured.forEach(hike => { %>
        <%- include('../partials/_hike-card', { hike }) %>
      <% }) %>
    </div>
    <div class="text-center" style="margin-top: 2.5rem;">
      <a href="/hikes" class="btn btn-secondary">View All Hikes</a>
    </div>
  </div>
</section>

<!-- WHY WANDERER -->
<section class="section section-dark">
  <div class="container">
    <div class="text-center" style="margin-bottom: 3rem;">
      <h2 class="section-title">Why <span class="text-accent">Wanderer</span>?</h2>
      <p class="section-subtitle centered">We don't just show you Georgia — we help you feel it.</p>
    </div>
    <div class="why-grid">
      <div class="why-card">
        <div class="why-icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--accent-orange)" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3>Safety First</h3>
        <p>Certified mountain guides, emergency protocols, satellite phones on every trek. Your safety is our top priority.</p>
      </div>
      <div class="why-card">
        <div class="why-icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--accent-orange)" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
        </div>
        <h3>Local Experts</h3>
        <p>Born and raised in the Caucasus, our guides know every trail, village, and hidden gem. Authentic local knowledge you can't find in guidebooks.</p>
      </div>
      <div class="why-card">
        <div class="why-icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--accent-orange)" stroke-width="1.5"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
        </div>
        <h3>Small Groups</h3>
        <p>Maximum 12 people per group ensures a personal, immersive experience. No mass tourism — just you, the mountains, and good company.</p>
      </div>
      <div class="why-card">
        <div class="why-icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--accent-orange)" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
        </div>
        <h3>All-Inclusive</h3>
        <p>Transport, meals, accommodation, and gear — all taken care of. Just bring your sense of adventure and we handle the rest.</p>
      </div>
    </div>
  </div>
</section>

<!-- TESTIMONIAL STRIP -->
<section class="section testimonial-strip">
  <div class="container">
    <div class="text-center" style="margin-bottom: 3rem;">
      <h2 class="section-title">What Hikers <span class="text-accent">Say</span></h2>
    </div>
    <div class="testimonial-grid">
      <% topReviews.forEach(review => { %>
        <% const hike = hikes.find(h => h.id === review.hikeId); %>
        <%- include('../partials/_review-card', { review, hikeName: hike ? hike.name : '' }) %>
      <% }) %>
    </div>
    <div class="text-center" style="margin-top: 2.5rem;">
      <a href="/reviews" class="btn btn-secondary">Read All Reviews</a>
    </div>
  </div>
</section>

<!-- CTA BANNER -->
<section class="cta-banner">
  <div class="cta-bg" style="background-image: url('https://picsum.photos/seed/wanderer-cta/1920/600')"></div>
  <div class="cta-overlay"></div>
  <div class="cta-content container">
    <h2>Ready for Your Georgian Adventure?</h2>
    <p>Join us on the trail and discover why the Caucasus is the world's next great hiking destination.</p>
    <a href="/booking" class="btn btn-primary">Book Your Adventure</a>
  </div>
</section>
