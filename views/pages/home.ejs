<!-- ============ HERO ============ -->
<section class="hero-home">
  <div class="container hero-home-inner">
    <p class="eyebrow"><%= lang === 'en' ? 'Discover Georgia · Caucasus Mountains' : 'აღმოაჩინე საქართველო · კავკასიონი' %></p>
    <h1>
      <% if (lang === 'en') { %>
        Explore Georgia through<br><span class="text-yellow">hiking adventures</span>
      <% } else { %>
        აღმოაჩინე საქართველო<br><span class="text-yellow">ლაშქრობით</span>
      <% } %>
    </h1>
    <p>
      <%= lang === 'en'
        ? 'Guided treks across the Caucasus — from alpine meadows in Kazbegi to the ancient trails of Tusheti. Certified guides, small groups, unforgettable routes.'
        : 'გიდიანი ტრეკინგი კავკასიონში — ყაზბეგის ალპური მინდვრებიდან თუშეთის უძველეს ბილიკებამდე. სერტიფიცირებული გამყოლები, მცირე ჯგუფები, დაუვიწყარი მარშრუტები.' %>
    </p>
    <div class="hero-home-ctas">
      <a href="<%= langPrefix %>/hikes" class="btn btn-accent btn-lg">
        <%= lang === 'en' ? 'Browse Tours' : 'ყველა ლაშქრობა' %>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
      <a href="<%= langPrefix %>/map" class="btn btn-white btn-lg"><%= lang === 'en' ? 'Explore the Map' : 'ინტერაქტიული რუკა' %></a>
    </div>

    <div class="hero-home-stats">
      <div class="hero-home-stat"><b>50+</b><span><%= lang === 'en' ? 'Curated routes' : 'მარშრუტი' %></span></div>
      <div class="hero-home-stat"><b>2,300+</b><span><%= lang === 'en' ? 'Happy hikers' : 'კმაყოფილი მოლაშქრე' %></span></div>
      <div class="hero-home-stat"><b>4.9★</b><span><%= lang === 'en' ? 'Traveler rating' : 'შეფასება' %></span></div>
      <div class="hero-home-stat"><b>12</b><span><%= lang === 'en' ? 'Years experience' : 'წლიანი გამოცდილება' %></span></div>
    </div>
  </div>
</section>

<!-- ============ SEARCH / DISCOVERY ============ -->
<div class="container">
  <div class="hero-search">
    <form class="hero-search-inner" action="<%= langPrefix %>/hikes" method="get" role="search">
      <div class="field">
        <label for="q"><%= lang === 'en' ? 'Destination' : 'მიმართულება' %></label>
        <input type="text" id="q" name="q" class="input" placeholder="<%= lang === 'en' ? 'e.g. Kazbegi, Tusheti, Svaneti…' : 'მაგ. ყაზბეგი, თუშეთი, სვანეთი…' %>">
      </div>
      <div class="field">
        <label for="type"><%= lang === 'en' ? 'Duration' : 'ხანგრძლივობა' %></label>
        <select id="type" name="type" class="select">
          <option value=""><%= lang === 'en' ? 'Any' : 'ნებისმიერი' %></option>
          <option value="day"><%= lang === 'en' ? 'Day hikes' : 'ერთდღიანი' %></option>
          <option value="multi-day"><%= lang === 'en' ? 'Multi-day treks' : 'მრავალდღიანი' %></option>
          <option value="cultural"><%= lang === 'en' ? 'Cultural tours' : 'კულტურული' %></option>
        </select>
      </div>
      <div class="field">
        <label for="difficulty"><%= lang === 'en' ? 'Difficulty' : 'სირთულე' %></label>
        <select id="difficulty" name="difficulty" class="select">
          <option value=""><%= lang === 'en' ? 'Any level' : 'ნებისმიერი' %></option>
          <option value="easy"><%= lang === 'en' ? 'Easy · Beginner' : 'მარტივი' %></option>
          <option value="medium"><%= lang === 'en' ? 'Moderate' : 'საშუალო' %></option>
          <option value="hard"><%= lang === 'en' ? 'Advanced' : 'რთული' %></option>
        </select>
      </div>
      <button class="btn btn-primary btn-lg" type="submit">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <%= lang === 'en' ? 'Search' : 'ძებნა' %>
      </button>
    </form>
  </div>
</div>

<!-- ============ TRUST BAR ============ -->
<div class="trust-bar" style="margin-top: var(--sp-20)">
  <div class="container">
    <div class="trust-bar-items">
      <span class="trust-bar-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg><%= lang === 'en' ? 'Certified mountain guides' : 'სერტიფიცირებული გამყოლები' %></span>
      <span class="trust-bar-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><%= lang === 'en' ? 'Insured adventures' : 'დაზღვეული თავგადასავალი' %></span>
      <span class="trust-bar-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg><%= lang === 'en' ? '24/7 local support' : '24/7 მხარდაჭერა' %></span>
      <span class="trust-bar-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg><%= lang === 'en' ? 'Loved by 2,300+ hikers' : 'უყვართ 2300+ მოლაშქრეს' %></span>
    </div>
  </div>
</div>

<!-- ============ FEATURED TOURS ============ -->
<section class="section">
  <div class="container">
    <div class="section-head align-between">
      <div>
        <p class="eyebrow"><%= lang === 'en' ? 'Featured hikes' : 'რეკომენდებული' %></p>
        <h2><%= lang === 'en' ? 'Hand-picked adventures for every explorer' : 'შერჩეული ლაშქრობები ყველა მოლაშქრისთვის' %></h2>
      </div>
      <a href="<%= langPrefix %>/hikes" class="section-head-link">
        <%= lang === 'en' ? 'All hiking tours' : 'ყველა ლაშქრობა' %>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>

    <div class="grid hikes-grid">
      <% if (featured && featured.length) { %>
        <% featured.forEach(hike => { %>
          <%- include('../partials/_hike-card', { hike }) %>
        <% }); %>
      <% } else if (hikes && hikes.length) { %>
        <% hikes.slice(0, 6).forEach(hike => { %>
          <%- include('../partials/_hike-card', { hike }) %>
        <% }); %>
      <% } else { %>
        <p class="text-muted"><%= lang === 'en' ? 'New tours coming soon.' : 'მალე გამოჩნდება ახალი ლაშქრობები.' %></p>
      <% } %>
    </div>
  </div>
</section>

<!-- ============ CATEGORIES ============ -->
<section class="section section-alt home-categories">
  <div class="container">
    <div class="section-head text-center" style="text-align:center; grid-template-columns: 1fr; justify-items: center">
      <p class="eyebrow"><%= lang === 'en' ? 'Find your pace' : 'აირჩიე შენი რიტმი' %></p>
      <h2><%= lang === 'en' ? 'Adventures for every level' : 'თავგადასავლები ყველა დონისთვის' %></h2>
    </div>

    <div class="grid">
      <a href="<%= langPrefix %>/hikes?difficulty=easy" class="category-card">
        <img src="/images/hikes-hero.jpeg" alt="Beginner hikes" loading="lazy">
        <div class="category-card-body">
          <h3><%= lang === 'en' ? 'Beginner' : 'დამწყებთათვის' %></h3>
          <p><%= lang === 'en' ? 'Easy day hikes. No experience needed.' : 'მარტივი, ერთდღიანი ლაშქრობები.' %></p>
        </div>
      </a>
      <a href="<%= langPrefix %>/hikes?difficulty=medium" class="category-card">
        <img src="/images/adventures-hero.jpeg" alt="Intermediate" loading="lazy">
        <div class="category-card-body">
          <h3><%= lang === 'en' ? 'Intermediate' : 'საშუალო დონე' %></h3>
          <p><%= lang === 'en' ? 'For active travelers with basic fitness.' : 'აქტიური მოგზაურებისთვის.' %></p>
        </div>
      </a>
      <a href="<%= langPrefix %>/hikes?difficulty=hard" class="category-card">
        <img src="/images/about-hero.jpeg" alt="Advanced" loading="lazy">
        <div class="category-card-body">
          <h3><%= lang === 'en' ? 'Advanced' : 'მოწინავე' %></h3>
          <p><%= lang === 'en' ? 'Serious treks in remote terrain.' : 'რთული ტრეკინგი.' %></p>
        </div>
      </a>
      <a href="<%= langPrefix %>/hikes?type=multi-day" class="category-card">
        <img src="/images/reviews-hero.jpeg" alt="Multi-day" loading="lazy">
        <div class="category-card-body">
          <h3><%= lang === 'en' ? 'Multi-day' : 'მრავალდღიანი' %></h3>
          <p><%= lang === 'en' ? 'Hut-to-hut treks, camping under stars.' : 'ქოხიდან ქოხამდე ტრეკინგი.' %></p>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- ============ WHY US ============ -->
<section class="why-us">
  <div class="container">
    <div class="section-head" style="max-width: 720px; margin-left: auto; margin-right: auto; text-align: center; grid-template-columns: 1fr; justify-items: center">
      <p class="eyebrow" style="color: var(--amber-300)"><%= lang === 'en' ? 'Why travelers choose Wanderer' : 'რატომ ირჩევენ Wanderer-ს' %></p>
      <h2><%= lang === 'en' ? 'Real adventures with people who know these mountains' : 'ნამდვილი თავგადასავლები მათთან, ვინც იცის ეს მთები' %></h2>
      <p class="lead"><%= lang === 'en' ? 'We grew up in the Caucasus. Every route we guide, we have walked dozens of times — in sun, snow, and storm.' : 'ჩვენ ვიზრდებოდით კავკასიონში. ყველა ბილიკი, რომლითაც ვუძღვებით ჯგუფებს, ათჯერ და ასჯერ გვქონია გავლილი.' %></p>
    </div>

    <div class="grid grid-3" style="margin-top: var(--sp-12)">
      <div class="feature">
        <div class="feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        </div>
        <h3><%= lang === 'en' ? 'Certified local guides' : 'სერტიფიცირებული ადგილობრივი გამყოლები' %></h3>
        <p><%= lang === 'en' ? 'All guides are certified by the Georgian Mountain Guide Association with wilderness first-aid training.' : 'ყველა გამყოლი სერტიფიცირებულია საქართველოს მთის გამყოლთა ასოციაციის მიერ.' %></p>
      </div>
      <div class="feature">
        <div class="feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
        </div>
        <h3><%= lang === 'en' ? 'Small groups' : 'მცირე ჯგუფები' %></h3>
        <p><%= lang === 'en' ? 'Max 12 hikers per guide. More attention, safer on the trail, better experience.' : 'მაქს. 12 მოლაშქრე ერთ გამყოლზე. მეტი ყურადღება, მეტი უსაფრთხოება.' %></p>
      </div>
      <div class="feature">
        <div class="feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3><%= lang === 'en' ? 'Safety first' : 'უსაფრთხოება ყველაფერზე მაღლა' %></h3>
        <p><%= lang === 'en' ? 'Insurance included, satellite communication on remote routes, clear cancellation policy.' : 'დაზღვევა შედის ფასში, სატელიტური კავშირი დაშორებულ მარშრუტებზე.' %></p>
      </div>
      <div class="feature">
        <div class="feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="4.93" y1="4.93" x2="9.17" y2="9.17"/><line x1="14.83" y1="14.83" x2="19.07" y2="19.07"/><line x1="14.83" y1="9.17" x2="19.07" y2="4.93"/><line x1="14.83" y1="9.17" x2="18.36" y2="5.64"/><line x1="4.93" y1="19.07" x2="9.17" y2="14.83"/></svg>
        </div>
        <h3><%= lang === 'en' ? 'Routes off the tourist trail' : 'ბილიკები ტურისტული გზებიდან მოშორებით' %></h3>
        <p><%= lang === 'en' ? 'We take you where group buses can\'t. Genuine encounters, untouched landscapes.' : 'იქ, სადაც ტურისტული ავტობუსები ვერ მიდიან.' %></p>
      </div>
      <div class="feature">
        <div class="feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21L21 3"/><path d="M3 21h6"/><path d="M21 3v6"/></svg>
        </div>
        <h3><%= lang === 'en' ? 'Transfers included' : 'ტრანსფერი შედის' %></h3>
        <p><%= lang === 'en' ? 'Door-to-trail logistics from Tbilisi or your hotel. No car rental needed.' : 'ტრანსპორტი თბილისიდან ან სასტუმროდან მარშრუტამდე.' %></p>
      </div>
      <div class="feature">
        <div class="feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </div>
        <h3><%= lang === 'en' ? 'English-speaking team' : 'ინგლისურენოვანი გუნდი' %></h3>
        <p><%= lang === 'en' ? 'Every guide speaks fluent English. We\'re on WhatsApp every day.' : 'გამყოლები თავისუფლად ფლობენ ინგლისურ ენას.' %></p>
      </div>
    </div>
  </div>
</section>

<!-- ============ GEAR SHOP PREVIEW ============ -->
<% if (featuredProducts && featuredProducts.length) { %>
<section class="section">
  <div class="container">
    <div class="section-head align-between">
      <div>
        <p class="eyebrow"><%= lang === 'en' ? 'Gear shop' : 'მაღაზია' %></p>
        <h2><%= lang === 'en' ? 'Curated hiking gear. Tested on our own trails.' : 'შერჩეული აღჭურვილობა, ჩვენივე ბილიკებზე გამოცდილი.' %></h2>
      </div>
      <a href="<%= langPrefix %>/shop" class="section-head-link">
        <%= lang === 'en' ? 'Shop everything' : 'მაღაზიაში' %>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>
    <div class="shop-strip">
      <% featuredProducts.forEach(product => { %>
        <%- include('../partials/_product-card', { product }) %>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

<!-- ============ TRANSFERS (supporting, subtle) ============ -->
<section class="section section-alt">
  <div class="container">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-12); align-items: center;" class="transfers-row">
      <div>
        <p class="eyebrow"><%= lang === 'en' ? 'Transfers &amp; logistics' : 'ტრანსფერი და ლოგისტიკა' %></p>
        <h2 style="font-size: var(--text-3xl)"><%= lang === 'en' ? 'Need a ride to the trailhead?' : 'საჭიროა ტრანსპორტი ლაშქრობის საწყის წერტილამდე?' %></h2>
        <p class="lead"><%= lang === 'en' ? 'Door-to-door transfers from Tbilisi, Kutaisi and Batumi airports to any trailhead in Georgia. Comfortable SUVs, experienced drivers, fixed prices.' : 'ტრანსპორტი თბილისის, ქუთაისის და ბათუმის აეროპორტებიდან ნებისმიერ საწყის წერტილამდე.' %></p>
        <div style="display: flex; gap: var(--sp-3); margin-top: var(--sp-6)">
          <a href="<%= langPrefix %>/contact#transfer" class="btn btn-primary"><%= lang === 'en' ? 'Request a transfer' : 'ტრანსფერის მოთხოვნა' %></a>
          <a href="<%= langPrefix %>/hikes" class="btn btn-ghost"><%= lang === 'en' ? 'Or book a hike (transfer included)' : 'ან დაჯავშნე ლაშქრობა' %></a>
        </div>
      </div>
      <div style="border-radius: var(--r-lg); overflow: hidden; aspect-ratio: 4 / 3; background: var(--stone-100)">
        <img src="/images/adventures-hero.jpeg" alt="" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;">
      </div>
    </div>
  </div>
</section>

<!-- ============ REVIEWS ============ -->
<section class="section">
  <div class="container">
    <div class="section-head" style="text-align: center; grid-template-columns: 1fr; justify-items: center; max-width: 720px; margin-left: auto; margin-right: auto">
      <p class="eyebrow"><%= lang === 'en' ? 'Travelers say' : 'მოგზაურები ამბობენ' %></p>
      <h2><%= lang === 'en' ? 'The real test: what our hikers say after the trek' : 'რას ამბობენ ჩვენი მოლაშქრეები' %></h2>
      <div style="margin-top: var(--sp-3)">
        <span class="rating" style="--star-size: 20px">
          <% for (let i = 0; i < 5; i++) { %>
            <svg viewBox="0 0 24 24" width="18" height="18"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <% } %>
        </span>
        <span style="font-weight: 700; margin-left: 8px">4.9 / 5</span>
        <span class="text-muted" style="margin-left: 6px"><%= lang === 'en' ? 'from 2,300+ reviews' : '2300+ მიმოხილვიდან' %></span>
      </div>
    </div>

    <div class="grid grid-3">
      <% if (topReviews && topReviews.length) { %>
        <% topReviews.forEach(review => { %>
          <%- include('../partials/_review-card', { review, hikeName: null }) %>
        <% }); %>
      <% } else { %>
        <!-- Placeholder reviews when data is empty -->
        <article class="review-card">
