            <div><div class="review-author">Sofia R.<span style="color: var(--text-muted); font-weight: 500"> · Spain</span></div><div style="font-size: var(--text-xs); color: var(--text-muted); margin-top: 2px">Tusheti 5-day trek</div></div>
