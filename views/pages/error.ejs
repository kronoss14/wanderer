<section class="notfound">
  <div class="container container-narrow">
    <p class="eyebrow" style="justify-content: center; display: inline-flex">Error</p>
    <h1>500</h1>
    <h2 style="font-size: var(--text-3xl); margin-bottom: var(--sp-4)"><%= lang === 'en' ? 'Something went wrong' : 'რაღაც შეცდომა მოხდა' %></h2>
    <p><%= lang === 'en' ? 'We\'re on it. Please try again in a moment, or head back home.' : 'ვცდილობთ მოვაგვაროთ. სცადეთ ცოტა ხანში.' %></p>
    <a href="<%= langPrefix %>/" class="btn btn-primary"><%= lang === 'en' ? 'Back home' : 'მთავარზე' %></a>
  </div>
</section>
