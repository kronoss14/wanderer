<!-- DETAIL HERO -->
<section class="detail-hero">
  <div class="detail-hero-bg" style="background-image: url('<%- escapeAttr(product.image || '') %>')"></div>
  <div class="detail-hero-overlay"></div>
  <div class="detail-hero-content container">
    <a href="<%= langPrefix %>/shop" class="back-link">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      <%= t('shop.back') %>
    </a>
    <h1><%= l(product, 'name') %></h1>
    <p class="detail-region"><%= t('shop.category.' + product.category) %></p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="detail-layout">
      <div class="detail-main">
        <% if (product.images && product.images.length) { %>
          <div class="detail-gallery-strip" style="margin-bottom:2rem;">
            <% product.images.forEach((img, i) => { %>
              <div class="detail-gallery-img gallery-item" data-full="<%- escapeAttr(img) %>" data-title="<%= l(product, 'name') %>">
                <img src="<%- escapeAttr(img) %>" alt="<%= l(product, 'name') %> - <%= i + 1 %>" loading="lazy">
              </div>
            <% }) %>
          </div>
        <% } %>

        <h2 class="detail-section-title"><%= t('shop.description') %></h2>
        <p class="detail-description"><%= l(product, 'description') %></p>
      </div>
      <aside class="detail-sidebar">
        <div class="booking-widget">
          <% if (product.originalPrice && product.originalPrice > product.price) { %>
            <p class="widget-price">
              <span class="widget-original-price">&#8382;<%= product.originalPrice %></span>
              <strong>&#8382;<%= product.price %></strong>
              <span class="widget-discount-badge">-<%= Math.round((1 - product.price / product.originalPrice) * 100) %>%</span>
            </p>
          <% } else { %>
            <p class="widget-price"><strong>&#8382;<%= product.price %></strong></p>
          <% } %>
          <% if (product.inStock !== false) { %>
            <p style="color:var(--accent-emerald);font-size:0.9rem;margin-bottom:1rem;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px;"><polyline points="20 6 9 17 4 12"/></svg>
              <%= t('shop.in_stock') %>
            </p>
            <button class="btn btn-primary btn-add-cart" style="width:100%;justify-content:center;" data-product-id="<%= product.id %>" data-product-name="<%= l(product, 'name') %>" data-product-price="<%= product.price %>" data-product-image="<%= product.image || '' %>">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
              <%= t('shop.add_to_cart') %>
            </button>
          <% } else { %>
            <p style="color:var(--text-muted);font-size:0.9rem;"><%= t('shop.out_of_stock') %></p>
          <% } %>
        </div>
      </aside>
    </div>
  </div>
</section>
