<section class="section">
  <div class="container">

    <nav class="crumbs">
      <a href="<%= langPrefix %>/"><%= lang === 'en' ? 'Home' : 'მთავარი' %></a>
      <span class="crumbs-sep">/</span>
      <a href="<%= langPrefix %>/shop"><%= lang === 'en' ? 'Shop' : 'მაღაზია' %></a>
      <span class="crumbs-sep">/</span>
      <span><%= l(product, 'name') %></span>
    </nav>

    <div class="shop-layout">

      <!-- Gallery -->
      <div>
        <% const gallery = (product.images && product.images.length) ? product.images : (product.image ? [product.image] : []); %>
        <div class="product-gallery">
          <% if (gallery.length > 1) { %>
          <div class="product-gallery-thumbs">
            <% gallery.forEach((img, i) => { %>
              <button type="button" data-img-src="<%= img %>" class="<%= i === 0 ? 'is-active' : '' %>" aria-label="Image <%= i+1 %>">
                <img src="<%= img %>" alt="" loading="lazy">
              </button>
            <% }); %>
          </div>
          <% } %>
          <div class="product-gallery-main">
            <% if (gallery.length) { %>
              <img id="product-main-img" src="<%= gallery[0] %>" alt="<%= l(product, 'name') %>">
            <% } else { %>
              <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: var(--stone-400)">
                <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Info -->
      <div class="product-main">
        <span class="badge badge-outline" style="margin-bottom: var(--sp-3)"><%= product.category || (lang === 'en' ? 'Gear' : 'აღჭურვილობა') %></span>
        <h1><%= l(product, 'name') %></h1>

        <div class="product-price">
          <b>₾<%= product.price %></b>
          <% if (product.originalPrice && product.originalPrice > product.price) { %>
            <s>₾<%= product.originalPrice %></s>
            <span class="badge badge-accent" style="margin-left: auto">-<%= Math.round((1 - product.price / product.originalPrice) * 100) %>%</span>
          <% } %>
        </div>

        <% if (l(product, 'description')) { %>
          <p style="font-size: var(--text-md); line-height: 1.75; color: var(--text-muted)"><%= l(product, 'description') %></p>
        <% } %>

        <hr class="divider divider-tight">

        <% if (product.inStock === false) { %>
          <div class="alert alert-warning">
            <strong><%= lang === 'en' ? 'Currently out of stock' : 'ამოიწურა' %></strong>
            <p style="margin:0"><%= lang === 'en' ? 'Leave your email and we\'ll notify you when it\'s back.' : 'მოგვწერეთ და შევატყობინებთ, როდესაც გამოჩნდება.' %></p>
          </div>
        <% } else { %>
          <form class="stack" method="post" action="<%= langPrefix %>/cart/add" id="add-to-cart-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="productId" value="<%= product.id %>">

            <div style="display: flex; gap: var(--sp-4); align-items: center">
              <label style="font-size: var(--text-xs); font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted)"><%= lang === 'en' ? 'Quantity' : 'რაოდენობა' %></label>
              <div class="qty-input">
                <button type="button" data-qty="-">−</button>
                <input type="number" name="quantity" value="1" min="1" max="10" id="qty-input">
                <button type="button" data-qty="+">+</button>
              </div>
            </div>

            <button type="submit" class="btn btn-primary btn-lg btn-block btn-add-cart" data-product-id="<%= product.id %>" data-product-name="<%= l(product, 'name') %>" data-product-price="<%= product.price %>" data-product-image="<%= product.image || '' %>">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
              <%= lang === 'en' ? 'Add to cart' : 'კალათაში დამატება' %>
            </button>
          </form>
        <% } %>

        <ul class="stack stack-sm" style="margin-top: var(--sp-8); font-size: var(--text-sm); color: var(--text-muted)">
          <li style="display: flex; gap: var(--sp-3); align-items: center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--forest-600)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 3h5v5M4 20L21 3M21 16v5h-5M15 15l6 6M4 4l5 5"/></svg>
            <%= lang === 'en' ? 'Free delivery in Tbilisi on orders over ₾200' : 'უფასო მიტანა თბილისში 200₾-ს ზემოთ შეკვეთებზე' %>
          </li>
          <li style="display: flex; gap: var(--sp-3); align-items: center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--forest-600)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
            <%= lang === 'en' ? '14-day return policy' : '14 დღიანი დაბრუნების პოლიტიკა' %>
          </li>
          <li style="display: flex; gap: var(--sp-3); align-items: center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--forest-600)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <%= lang === 'en' ? 'Advice from real guides — call us' : 'ვუპასუხებთ კითხვებს — დაგვირეკეთ' %>
          </li>
        </ul>
      </div>

    </div>
  </div>
</section>

<script>
  // Thumbnail switching
  document.querySelectorAll('.product-gallery-thumbs button').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.product-gallery-thumbs button').forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      const mainImg = document.getElementById('product-main-img');
      if (mainImg) mainImg.src = btn.dataset.imgSrc;
    });
  });
  // Qty buttons
  document.querySelectorAll('[data-qty]').forEach(btn => {
    btn.addEventListener('click', () => {
      const input = document.getElementById('qty-input');
      if (!input) return;
      let v = parseInt(input.value, 10) || 1;
      v += btn.dataset.qty === '+' ? 1 : -1;
      input.value = Math.max(1, Math.min(10, v));
    });
  });
</script>
