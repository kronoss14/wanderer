<section class="page-hero">
  <div class="page-hero-bg" style="background-image: url('/images/contact-hero.jpeg'); background-position: center 55%"></div>
  <div class="page-hero-overlay"></div>
  <div class="page-hero-content container">
    <p class="eyebrow"><%= lang === 'en' ? 'Let\'s plan your adventure' : 'დავგეგმოთ თქვენი თავგადასავალი' %></p>
    <h1><%= lang === 'en' ? 'Get in Touch' : 'დაგვიკავშირდით' %></h1>
    <p><%= lang === 'en' ? 'Questions about a specific hike, custom trip, or a transfer? Drop us a line — we usually reply within a few hours.' : 'გაქვთ შეკითხვა? დაგვიკავშირდით — ჩვეულებრივ ვპასუხობთ რამდენიმე საათში.' %></p>
  </div>
</section>

<section class="section">
  <div class="container">

    <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert-success" style="margin-bottom: var(--sp-8)">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <div>
          <strong><%= lang === 'en' ? 'Message sent!' : 'შეტყობინება გაიგზავნა!' %></strong>
          <p style="margin: 4px 0 0"><%= lang === 'en' ? 'We\'ll get back to you shortly.' : 'მალე დაგიკავშირდებით.' %></p>
        </div>
      </div>
    <% } %>

    <div class="contact-layout">
      <aside>
        <div class="contact-card">
          <h3><%= lang === 'en' ? 'Talk to the team' : 'დაგვიკავშირდით' %></h3>
          <p class="text-muted" style="margin-bottom: var(--sp-6)"><%= lang === 'en' ? 'Real people, real fast. We reply to most messages within 3–4 hours during the day.' : 'ნამდვილი ადამიანები, სწრაფი პასუხები.' %></p>
          <div class="footer-contact-item" style="color: var(--text)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--forest-600)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Tbilisi, Georgia</span>
          </div>
          <div class="footer-contact-item" style="color: var(--text)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--forest-600)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <a href="mailto:Wandererinfo24@gmail.com">Wandererinfo24@gmail.com</a>
          </div>
          <div class="footer-contact-item" style="color: var(--text)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--forest-600)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <a href="tel:+995568730184">+995 568 73 01 84</a>
          </div>
          <div class="footer-contact-item" style="color: var(--text)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--forest-600)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span><%= lang === 'en' ? 'Mon–Sun, 9:00 – 21:00 Georgia time' : 'ორშ–კვ, 9:00 – 21:00' %></span>
          </div>

          <hr class="divider divider-tight">
          <div style="display: flex; gap: var(--sp-2)">
            <a href="<%= socialLinks.facebook %>" target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-sm">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              Facebook
            </a>
            <a href="<%= socialLinks.instagram %>" target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-sm">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              Instagram
            </a>
          </div>
        </div>

        <!-- Transfer callout -->
        <div class="contact-card" id="transfer" style="margin-top: var(--sp-5); background: var(--forest-50); border-color: var(--forest-100)">
          <h3><%= lang === 'en' ? 'Need a transfer?' : 'გჭირდებათ ტრანსფერი?' %></h3>
          <p class="text-muted"><%= lang === 'en' ? 'Airport pickups and trail-head drops across Georgia. Drop your details and we\'ll send a fixed quote.' : 'აეროპორტიდან წაყვანა და ჩამოყვანა ლაშქრობის საწყის წერტილამდე.' %></p>
        </div>
      </aside>

      <div>
        <div class="contact-card">
          <h3><%= lang === 'en' ? 'Send us a message' : 'გამოგვიგზავნეთ შეტყობინება' %></h3>
          <form action="<%= langPrefix %>/contact" method="POST" class="stack stack-sm" id="contact-form" novalidate>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-4)" class="fields-row">
              <div class="field">
                <label for="name"><%= lang === 'en' ? 'Your name' : 'სახელი' %></label>
                <input type="text" id="name" name="name" class="input" required>
              </div>
              <div class="field">
                <label for="email"><%= lang === 'en' ? 'Email' : 'ელ. ფოსტა' %></label>
                <input type="email" id="email" name="email" class="input" required>
              </div>
            </div>
            <div class="field">
              <label for="subject"><%= lang === 'en' ? 'Subject' : 'თემა' %></label>
              <input type="text" id="subject" name="subject" class="input" required placeholder="<%= lang === 'en' ? 'e.g. Kazbegi trek for 4 people' : 'მაგ. ყაზბეგის ლაშქრობა 4 ადამიანისთვის' %>">
            </div>
            <div class="field">
              <label for="message"><%= lang === 'en' ? 'Message' : 'შეტყობინება' %></label>
              <textarea id="message" name="message" class="textarea" rows="8" required></textarea>
            </div>
            <button type="submit" class="btn btn-primary btn-lg"><%= lang === 'en' ? 'Send message' : 'გაგზავნა' %></button>
          </form>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  @media (max-width: 560px) {
    .fields-row { grid-template-columns: 1fr !important; }
  }
</style>
