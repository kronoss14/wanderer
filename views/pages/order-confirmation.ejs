<section class="section">
  <div class="container container-narrow">

    <div class="text-center" style="padding: var(--sp-10) 0">
      <div style="width: 84px; height: 84px; background: #ebf7ef; border-radius: var(--r-full); display: inline-flex; align-items: center; justify-content: center; margin-bottom: var(--sp-5)">
        <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="var(--success)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <h1 style="margin-bottom: var(--sp-3)"><%= lang === 'en' ? 'Order confirmed!' : 'შეკვეთა დადასტურდა!' %></h1>
      <p class="lead"><%= lang === 'en' ? 'Thanks — we\'ve received your order and will process it shortly.' : 'გმადლობთ, შეკვეთა მიღებულია.' %></p>
    </div>

    <div class="card" style="padding: var(--sp-8); display: block">
      <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: var(--sp-3); margin-bottom: var(--sp-5)">
        <div>
          <p class="text-muted" style="font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 4px"><%= lang === 'en' ? 'Order ID' : 'შეკვეთის ID' %></p>
          <strong style="font-family: var(--font-mono); font-size: var(--text-lg)"><%= order.id %></strong>
        </div>
        <div style="color: var(--text-muted); font-size: var(--text-sm)">
          <%= new Date(order.createdAt).toLocaleString(lang === 'en' ? 'en-US' : 'ka-GE') %>
        </div>
      </div>

      <table class="cart-table" style="margin-bottom: var(--sp-4)">
        <thead>
          <tr>
            <th><%= lang === 'en' ? 'Product' : 'პროდუქტი' %></th>
            <th><%= lang === 'en' ? 'Qty' : 'რაოდ.' %></th>
            <th style="text-align: right"><%= lang === 'en' ? 'Subtotal' : 'ჯამი' %></th>
          </tr>
        </thead>
        <tbody>
          <% order.items.forEach(item => { %>
            <tr>
              <td><%= item.name %></td>
              <td><%= item.quantity %></td>
              <td style="text-align: right">₾<%= (item.price * item.quantity).toFixed(2) %></td>
            </tr>
          <% }); %>
        </tbody>
        <tfoot>
          <tr>
            <td colspan="2" style="text-align: right; font-weight: 700"><%= lang === 'en' ? 'Total' : 'ჯამი' %></td>
            <td style="text-align: right; font-weight: 700; font-size: var(--text-lg); color: var(--forest-800)">₾<%= order.total.toFixed(2) %></td>
          </tr>
        </tfoot>
      </table>

      <% if (order.paymentMethod === 'bank_transfer') { %>
        <div class="card" style="padding: var(--sp-5); display: block; background: var(--forest-50); border-color: var(--forest-100)">
          <h3 style="font-family: var(--font-body); font-weight: 700; font-size: var(--text-base); margin-bottom: var(--sp-3)">💳 <%= lang === 'en' ? 'Bank transfer details' : 'ბანკის გადარიცხვის დეტალები' %></h3>
          <div class="stack stack-sm" style="font-size: var(--text-sm)">
            <div style="display: flex; justify-content: space-between"><span class="text-muted"><%= lang === 'en' ? 'Recipient' : 'მიმღები' %></span><strong><%= bankDetails.bog.holder %></strong></div>
            <div style="display: flex; justify-content: space-between"><span class="text-muted">IBAN (BOG)</span><strong style="font-family: var(--font-mono)"><%= bankDetails.bog.iban %></strong></div>
            <div style="display: flex; justify-content: space-between"><span class="text-muted">IBAN (TBC)</span><strong style="font-family: var(--font-mono)"><%= bankDetails.tbc.iban %></strong></div>
            <div style="display: flex; justify-content: space-between"><span class="text-muted"><%= lang === 'en' ? 'Amount' : 'თანხა' %></span><strong>₾<%= order.total.toFixed(2) %></strong></div>
            <div style="display: flex; justify-content: space-between"><span class="text-muted"><%= lang === 'en' ? 'Reference' : 'საფუძველი' %></span><strong style="font-family: var(--font-mono)"><%= order.id %></strong></div>
          </div>
        </div>
      <% } else if (order.paymentMethod === 'on_delivery') { %>
        <div class="alert alert-info"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/></svg><div><%= lang === 'en' ? 'Pay in cash when your order arrives.' : 'გადაიხადეთ მიტანისას ნაღდი ფულით.' %></div></div>
      <% } else if (order.paymentMethod === 'on_pickup') { %>
        <div class="alert alert-info"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/></svg><div><%= lang === 'en' ? 'Pay at our pickup location in Tbilisi.' : 'გადაიხადეთ თბილისში აღებისას.' %></div></div>
      <% } %>
    </div>

    <div class="text-center" style="margin-top: var(--sp-8)">
      <a href="<%= langPrefix %>/shop" class="btn btn-outline"><%= lang === 'en' ? 'Continue shopping' : 'განვაგრძოთ' %></a>
      <a href="<%= langPrefix %>/" class="btn btn-ghost"><%= lang === 'en' ? 'Back home' : 'მთავარზე დაბრუნება' %></a>
    </div>

  </div>
</section>

<script>
  localStorage.removeItem('wanderer_cart');
  if (typeof updateCartBadge === 'function') updateCartBadge();
</script>
