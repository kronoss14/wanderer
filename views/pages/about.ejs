<!-- PAGE HERO -->
<section class="page-hero">
  <div class="page-hero-bg" style="background-image: url('https://picsum.photos/seed/about-hero/1920/600')"></div>
  <div class="page-hero-overlay"></div>
  <div class="page-hero-content container">
    <h1>About <span class="text-accent">Wanderer</span></h1>
    <p>Our story, our values, and the passionate team behind your Georgian adventure.</p>
  </div>
</section>

<!-- OUR STORY -->
<section class="section">
  <div class="container">
    <div class="about-story">
      <div class="about-story-text">
        <h2 class="section-title">Our <span class="text-accent">Story</span></h2>
        <p>Wanderer was born from a simple belief: that Georgia's mountains are among the most beautiful and underexplored hiking destinations on Earth.</p>
        <p>Founded in 2018 by Giorgi Khachidze, a lifelong mountaineer from Stepantsminda, Wanderer started with a single mission — to share the raw beauty of the Caucasus with travelers who crave authentic adventure over tourist clich&eacute;s.</p>
        <p>What began as weekend hikes for friends quickly grew into a full-service adventure tourism company. Today, we lead hundreds of hikers each season through Svaneti's tower-studded valleys, Tusheti's wild highlands, Kazbegi's glacier-carved peaks, and Tbilisi's enchanting streets.</p>
        <p>But at our core, we're still the same: a small team of passionate locals who believe the best way to know Georgia is on foot, with good company and a warm meal waiting at the end of the trail.</p>
      </div>
      <div class="about-story-image">
        <img src="https://picsum.photos/seed/about-story/600/700" alt="Our team in the Caucasus mountains">
      </div>
    </div>
  </div>
</section>

<!-- VALUES -->
<section class="section section-dark">
  <div class="container">
    <div class="text-center" style="margin-bottom: 3rem;">
      <h2 class="section-title">Our <span class="text-accent">Values</span></h2>
    </div>
    <div class="values-grid">
      <div class="value-card">
        <div class="value-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--accent-emerald)" stroke-width="1.5"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
        </div>
        <h3>Authentic Experiences</h3>
        <p>We go beyond the tourist trail to show you the real Georgia — its people, traditions, and hidden corners.</p>
      </div>
      <div class="value-card">
        <div class="value-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--accent-emerald)" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3>Safety & Trust</h3>
        <p>Certified guides, proper equipment, emergency protocols. We never compromise on your safety in the mountains.</p>
      </div>
      <div class="value-card">
        <div class="value-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--accent-emerald)" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <h3>Sustainable Tourism</h3>
        <p>We support local communities, minimize environmental impact, and ensure our trails remain pristine for generations.</p>
      </div>
      <div class="value-card">
        <div class="value-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--accent-emerald)" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
        </div>
        <h3>Personal Connection</h3>
        <p>Small groups mean personal attention. We remember your name, your preferences, and your sense of adventure.</p>
      </div>
    </div>
  </div>
</section>

<!-- OUR GUIDES -->
<section class="section">
  <div class="container">
    <div class="text-center" style="margin-bottom: 3rem;">
      <h2 class="section-title">Meet Our <span class="text-accent">Guides</span></h2>
      <p class="section-subtitle centered">The heart and soul of every Wanderer adventure.</p>
    </div>
    <div class="guides-grid">
      <% guides.forEach(guide => { %>
        <div class="guide-card">
          <div class="guide-image">
            <img src="<%= guide.image %>" alt="<%= guide.name %>">
          </div>
          <div class="guide-info">
            <h3><%= guide.name %></h3>
            <p class="guide-role"><%= guide.role %></p>
            <p class="guide-bio"><%= guide.bio %></p>
            <div class="guide-specialties">
              <% guide.specialties.forEach(s => { %>
                <span class="specialty-tag"><%= s %></span>
              <% }) %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>
