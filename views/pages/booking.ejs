<!-- PAGE HERO -->
<section class="page-hero">
  <div class="page-hero-bg" style="background-image: url('https://picsum.photos/seed/booking-hero/1920/600')"></div>
  <div class="page-hero-overlay"></div>
  <div class="page-hero-content container">
    <h1>ფასები და <span class="text-accent">ჯავშანი</span></h1>
    <p>გამჭვირვალე ფასები, მოქნილი პირობები და მარტივი ჯავშანი თქვენი ქართული თავგადასავლისთვის.</p>
  </div>
</section>

<!-- PRICING TIERS -->
<section class="section">
  <div class="container">
    <div class="text-center" style="margin-bottom: 3rem;">
      <h2 class="section-title">აირჩიეთ თქვენი <span class="text-accent">თავგადასავალი</span></h2>
      <p class="section-subtitle centered">ყველა ფასი თითო ადამიანზეა. 6+ მოგზაურისთვის ჯგუფური ფასდაკლება მოქმედებს.</p>
    </div>
    <div class="pricing-grid">
      <% pricing.forEach(tier => { %>
        <div class="pricing-card<%= tier.highlighted ? ' pricing-highlighted' : '' %>">
          <% if (tier.highlighted) { %><span class="pricing-badge">ყველაზე პოპულარული</span><% } %>
          <h3 class="pricing-tier"><%= tier.tier %></h3>
          <div class="pricing-price">
            <span class="pricing-amount"><%= tier.priceLabel %></span>
            <span class="pricing-unit"><%= tier.unit %></span>
          </div>
          <p class="pricing-desc"><%= tier.description %></p>
          <ul class="pricing-features">
            <% tier.features.forEach(f => { %>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent-emerald)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                <%= f %>
              </li>
            <% }) %>
          </ul>
          <a href="#booking-form" class="btn <%= tier.highlighted ? 'btn-primary' : 'btn-secondary' %>" style="width:100%;justify-content:center;"><%= tier.cta %></a>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- BOOKING FORM -->
<section class="section section-dark" id="booking-form">
  <div class="container" style="max-width: 700px;">
    <% if (success) { %>
      <div class="success-message">
        <h3>მოთხოვნა მიღებულია!</h3>
        <p>გმადლობთ ჯავშნის მოთხოვნისთვის. 24 საათის განმავლობაში გამოგიგზავნით დეტალურ შეთავაზებას და ხელმისაწვდომობის ინფორმაციას.</p>
      </div>
    <% } %>
    <div class="text-center" style="margin-bottom: 2.5rem;">
      <h2 class="section-title">დაჯავშნეთ თქვენი <span class="text-accent">თავგადასავალი</span></h2>
      <p class="section-subtitle centered">შეავსეთ ქვემოთ მოცემული ფორმა და ჩვენ ხელმისაწვდომობისა და დეტალური შეთავაზების შესახებ გიპასუხებთ.</p>
    </div>
    <form action="/booking" method="POST" class="booking-form" id="booking-form-el" novalidate>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="b-name">თქვენი სახელი *</label>
          <input type="text" id="b-name" name="name" class="form-input" required>
          <p class="form-error">გთხოვთ, შეიყვანოთ სახელი.</p>
        </div>
        <div class="form-group">
          <label class="form-label" for="b-email">ელ. ფოსტა *</label>
          <input type="email" id="b-email" name="email" class="form-input" required>
          <p class="form-error">გთხოვთ, შეიყვანოთ სწორი ელ. ფოსტა.</p>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="b-phone">ტელეფონის ნომერი</label>
          <input type="tel" id="b-phone" name="phone" class="form-input">
        </div>
        <div class="form-group">
          <label class="form-label" for="b-group">ჯგუფის ზომა *</label>
          <select id="b-group" name="groupSize" class="form-select" required>
            <option value="">აირჩიეთ...</option>
            <option value="1">1 ადამიანი</option>
            <option value="2">2 ადამიანი</option>
            <option value="3-4">3-4 ადამიანი</option>
            <option value="5-8">5-8 ადამიანი</option>
            <option value="9+">9+ ადამიანი</option>
          </select>
          <p class="form-error">გთხოვთ, აირჩიოთ ჯგუფის ზომა.</p>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="b-hike">სასურველი ლაშქრობა *</label>
          <select id="b-hike" name="hikeId" class="form-select" required>
            <option value="">აირჩიეთ ლაშქრობა...</option>
            <% hikes.forEach(h => { %>
              <option value="<%= h.id %>"><%= h.name %> ($<%= h.price %>)</option>
            <% }) %>
            <option value="custom">ინდივიდუალური ტური (შეთავაზების მოთხოვნა)</option>
          </select>
          <p class="form-error">გთხოვთ, აირჩიოთ ლაშქრობა.</p>
        </div>
        <div class="form-group">
          <label class="form-label" for="b-date">სასურველი თარიღი *</label>
          <input type="date" id="b-date" name="preferredDate" class="form-input" required>
          <p class="form-error">გთხოვთ, აირჩიოთ თარიღი.</p>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label" for="b-message">დამატებითი შენიშვნები</label>
        <textarea id="b-message" name="message" class="form-textarea" rows="4" placeholder="მოგვიყევით სპეციალური მოთხოვნების, დიეტური საჭიროებების ან კითხვების შესახებ..."></textarea>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">ჯავშნის მოთხოვნის გაგზავნა</button>
    </form>
  </div>
</section>
