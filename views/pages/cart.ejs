<section class="section">
  <div class="container">
    <h1 style="margin-bottom:2rem;"><%= t('cart.title') %></h1>

    <div id="cart-empty" style="display:none;">
      <p class="text-center" style="color:var(--text-secondary);padding:3rem 0;"><%= t('cart.empty') %></p>
      <div class="text-center">
        <a href="<%= langPrefix %>/shop" class="btn btn-primary"><%= t('cart.continue_shopping') %></a>
      </div>
    </div>

    <div id="cart-content" style="display:none;">
      <div class="cart-table-wrap">
        <table class="cart-table">
          <thead>
            <tr>
              <th></th>
              <th><%= t('cart.product') %></th>
              <th><%= t('cart.price') %></th>
              <th><%= t('cart.quantity') %></th>
              <th><%= t('cart.subtotal') %></th>
              <th></th>
            </tr>
          </thead>
          <tbody id="cart-items">
          </tbody>
          <tfoot>
            <tr>
              <td colspan="4" style="text-align:right;font-weight:700;"><%= t('cart.total') %></td>
              <td style="font-weight:700;color:var(--accent-emerald);" id="cart-total">&#8382;0</td>
              <td></td>
            </tr>
          </tfoot>
        </table>
      </div>
      <div style="display:flex;gap:1rem;justify-content:flex-end;margin-top:1.5rem;flex-wrap:wrap;">
        <a href="<%= langPrefix %>/shop" class="btn btn-secondary"><%= t('cart.continue_shopping') %></a>
        <a href="<%= langPrefix %>/cart/checkout" class="btn btn-primary" id="checkout-btn"><%= t('cart.checkout') %></a>
      </div>
    </div>
  </div>
</section>
