<!-- PAGE HERO -->
<section class="page-hero">
  <div class="page-hero-bg" style="background-image: url('/images/hikes-hero.jpeg'); background-position: center 65%"></div>
  <div class="page-hero-overlay" style="background: linear-gradient(135deg, rgba(13,13,13,0.45) 0%, rgba(26,26,46,0.35) 100%)"></div>
  <div class="page-hero-content container">
    <h1><%- t('hikes.title') %></h1>
    <p><%= t('hikes.subtitle') %></p>
  </div>
</section>

<!-- FILTER + GRID -->
<section class="section">
  <div class="container">
    <div class="filter-bar">
      <a href="<%= langPrefix %>/hikes" class="filter-btn<%= activeType === 'all' ? ' active' : '' %>"><%= t('hikes.filter_all') %></a>
      <a href="<%= langPrefix %>/hikes?type=day" class="filter-btn<%= activeType === 'day' ? ' active' : '' %>"><%= t('hikes.filter_day') %></a>
      <a href="<%= langPrefix %>/hikes?type=multi-day" class="filter-btn<%= activeType === 'multi-day' ? ' active' : '' %>"><%= t('hikes.filter_multi') %></a>
      <a href="<%= langPrefix %>/hikes?type=cultural" class="filter-btn<%= activeType === 'cultural' ? ' active' : '' %>"><%= t('hikes.filter_cultural') %></a>
    </div>
    <% if (hikes.length === 0) { %>
      <p class="text-center" style="color: var(--text-secondary); padding: 3rem 0;"><%= t('hikes.empty') %></p>
    <% } else { %>
      <div class="hike-grid">
        <% hikes.forEach(hike => { %>
          <%- include('../partials/_hike-card', { hike }) %>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>
