<!-- PAGE HERO -->
<section class="page-hero">
  <div class="page-hero-bg" style="background-image: url('https://picsum.photos/seed/hikes-hero/1920/600')"></div>
  <div class="page-hero-overlay"></div>
  <div class="page-hero-content container">
    <h1>ჩვენი <span class="text-accent">ლაშქრობები</span></h1>
    <p>ერთდღიანი მარშრუტები, მრავალდღიანი ტრეკინგი და კულტურული მოგზაურობები საქართველოს ულამაზეს ლანდშაფტებში.</p>
  </div>
</section>

<!-- FILTER + GRID -->
<section class="section">
  <div class="container">
    <div class="filter-bar">
      <a href="/hikes" class="filter-btn<%= activeType === 'all' ? ' active' : '' %>">ყველა</a>
      <a href="/hikes?type=day" class="filter-btn<%= activeType === 'day' ? ' active' : '' %>">ერთდღიანი</a>
      <a href="/hikes?type=multi-day" class="filter-btn<%= activeType === 'multi-day' ? ' active' : '' %>">მრავალდღიანი</a>
      <a href="/hikes?type=cultural" class="filter-btn<%= activeType === 'cultural' ? ' active' : '' %>">კულტურული</a>
    </div>
    <% if (hikes.length === 0) { %>
      <p class="text-center" style="color: var(--text-secondary); padding: 3rem 0;">ამ კატეგორიაში ლაშქრობები ვერ მოიძებნა.</p>
    <% } else { %>
      <div class="hike-grid">
        <% hikes.forEach(hike => { %>
          <%- include('../partials/_hike-card', { hike }) %>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>
