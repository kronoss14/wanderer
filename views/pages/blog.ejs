<section class="page-hero" style="min-height: 260px">
  <div class="page-hero-bg" style="background-image: url('/images/hikes-hero.jpeg'); background-position: center 65%"></div>
  <div class="page-hero-overlay"></div>
  <div class="page-hero-content container">
    <p class="eyebrow"><%= lang === 'en' ? 'Stories from the trail' : 'ისტორიები ბილიკიდან' %></p>
    <h1><%= lang === 'en' ? 'Blog &amp; Trail Guides' : 'ბლოგი' %></h1>
    <p><%= lang === 'en' ? 'Route notes, gear tips, seasonal advice, and the stories behind our favourite trails.' : 'მარშრუტების შესახებ, აღჭურვილობის რჩევები, სეზონური ინფორმაცია.' %></p>
  </div>
</section>

<section class="section">
  <div class="container">
    <% if (allTags && allTags.length) { %>
      <div class="hikes-toolbar" style="margin-bottom: var(--sp-8)">
        <strong style="font-size: var(--text-sm); color: var(--text-muted); letter-spacing: 0.08em; text-transform: uppercase; margin-right: var(--sp-4);"><%= lang === 'en' ? 'Topics' : 'თემები' %></strong>
        <a href="<%= langPrefix %>/blog" class="chip<%= !activeTag ? ' is-active' : '' %>"><%= lang === 'en' ? 'All' : 'ყველა' %></a>
        <% allTags.forEach(function(tag) { %>
          <a href="<%= langPrefix %>/blog?tag=<%= encodeURIComponent(tag) %>" class="chip<%= activeTag === tag ? ' is-active' : '' %>"><%= tag %></a>
        <% }); %>
      </div>
    <% } %>

    <% if (posts && posts.length) { %>
      <div class="blog-grid">
        <% posts.forEach(function(post) { %>
          <article class="blog-post">
            <% if (post.coverImage) { %>
              <a href="<%= langPrefix %>/blog/<%= post.slug %>" class="blog-post-media">
                <img src="<%= post.coverImage %>" alt="<%= l(post, 'title') %>" loading="lazy">
              </a>
            <% } %>
            <div class="blog-post-body">
              <div class="blog-post-date"><%= new Date(post.publishedAt).toLocaleDateString(lang === 'en' ? 'en-US' : 'ka-GE', { year: 'numeric', month: 'long', day: 'numeric' }) %></div>
              <h2 class="blog-post-title"><a href="<%= langPrefix %>/blog/<%= post.slug %>"><%= l(post, 'title') %></a></h2>
              <p class="card-excerpt"><%= (l(post, 'content') || '').split('\n')[0].replace(/^#+\s*/, '').substring(0, 180) %></p>
              <% if (post.tags && post.tags.length) { %>
                <div style="display: flex; gap: var(--sp-2); flex-wrap: wrap; margin-top: auto; padding-top: var(--sp-3); border-top: 1px dashed var(--border)">
                  <% post.tags.slice(0, 3).forEach(function(tag) { %><span class="badge badge-outline"><%= tag %></span><% }); %>
                </div>
              <% } %>
            </div>
          </article>
        <% }); %>
      </div>
    <% } else { %>
      <div class="alert alert-info" style="max-width: 560px; margin: var(--sp-12) auto">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/></svg>
        <div><%= lang === 'en' ? 'New stories coming soon. Follow us on Instagram in the meantime.' : 'მალე გამოჩნდება ახალი ისტორიები.' %></div>
      </div>
    <% } %>
  </div>
</section>
