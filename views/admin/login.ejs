<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign in — Wanderer Admin</title>
  <link rel="icon" type="image/png" href="/images/favicon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body admin-login">
  <div class="admin-login-card">
    <div style="display: flex; justify-content: center; margin-bottom: 20px">
      <div class="admin-brand-mark" style="width: 56px; height: 56px; font-size: 24px">W</div>
    </div>
    <h1 style="font-size: 22px; text-align: center">Wanderer Admin</h1>
    <p class="admin-muted" style="text-align: center; margin-bottom: 32px; font-size: 13px">Enter your admin password to continue</p>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="admin-flash admin-flash-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/admin/login">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="admin-field">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" class="admin-input" required autofocus>
      </div>
      <button type="submit" class="admin-btn admin-btn-primary" style="width: 100%">Sign In</button>
    </form>

    <div style="text-align: center; margin-top: 24px">
      <a href="/" style="font-size: 12px; color: var(--a-text-muted)">← Back to public site</a>
    </div>
  </div>
</body>
</html>
