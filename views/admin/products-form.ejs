<div class="admin-header">
  <h1><%= editing ? 'Edit Product' : 'New Product' %></h1>
</div>

<% if (typeof errors !== 'undefined' && errors && errors.length) { %>
  <div class="flash flash-error">
    <ul style="margin:0;padding-left:1.5rem;">
      <% errors.forEach(e => { %><li><%= e.msg %></li><% }) %>
    </ul>
  </div>
<% } %>

<form class="admin-form" method="POST" action="<%= editing ? '/admin/products/edit/' + product.id : '/admin/products' %>">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <div class="form-lang-row">
    <div class="form-group">
      <label for="name">Name (KA)</label>
      <input type="text" id="name" name="name" value="<%= product.name || '' %>" required>
    </div>
    <div class="form-group">
      <label for="name_en">Name (EN)</label>
      <input type="text" id="name_en" name="name_en" value="<%= product.name_en || '' %>">
    </div>
  </div>

  <div class="form-group">
    <label for="category">Category</label>
    <select id="category" name="category">
      <option value="gear" <%= product.category === 'gear' ? 'selected' : '' %>>Gear</option>
      <option value="clothing" <%= product.category === 'clothing' ? 'selected' : '' %>>Clothing</option>
      <option value="accessories" <%= product.category === 'accessories' ? 'selected' : '' %>>Accessories</option>
      <option value="equipment" <%= product.category === 'equipment' ? 'selected' : '' %>>Equipment</option>
    </select>
  </div>

  <div class="form-group">
    <label for="price">Price (&#8382;)</label>
    <input type="number" id="price" name="price" value="<%= product.price || '' %>" min="0" step="0.01">
  </div>

  <div class="form-lang-row">
    <div class="form-group">
      <label for="description">Description (KA)</label>
      <textarea id="description" name="description" rows="5"><%= product.description || '' %></textarea>
    </div>
    <div class="form-group">
      <label for="description_en">Description (EN)</label>
      <textarea id="description_en" name="description_en" rows="5"><%= product.description_en || '' %></textarea>
    </div>
  </div>

  <div class="form-group">
    <label for="image">Main Image URL</label>
    <input type="text" id="image" name="image" value="<%= product.image || '' %>" data-upload="single">
  </div>

  <div class="form-group">
    <label for="images">Additional Images</label>
    <div class="hint">One URL per line</div>
    <textarea id="images" name="images" rows="4" data-upload="multi"><%= (product.images || []).join('\n') %></textarea>
  </div>

  <div class="form-group">
    <label class="checkbox-label">
      <input type="checkbox" name="inStock" value="true" <%= product.inStock !== false ? 'checked' : '' %>>
      In Stock
    </label>
  </div>

  <div class="form-group">
    <label class="checkbox-label">
      <input type="checkbox" name="featured" value="true" <%= product.featured ? 'checked' : '' %>>
      Featured
    </label>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary"><%= editing ? 'Update Product' : 'Create Product' %></button>
    <a href="/admin/products" class="btn btn-secondary">Cancel</a>
  </div>
</form>
