<div class="admin-header">
  <h1>Guides</h1>
  <a href="/admin/guides/new" class="btn btn-primary">+ New Guide</a>
</div>

<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Role</th>
        <th>Specialties</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% guides.forEach(g => { %>
        <tr>
          <td><%= g.id %></td>
          <td><%= g.name %></td>
          <td><%= g.role %></td>
          <td><%= (g.specialties || []).join(', ') %></td>
          <td class="actions">
            <a href="/admin/guides/edit/<%= g.id %>" class="btn btn-secondary btn-sm">Edit</a>
            <form method="POST" action="/admin/guides/delete/<%= g.id %>" onsubmit="return confirm('Delete this guide?')">
              <button type="submit" class="btn btn-danger btn-sm">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
      <% if (!guides.length) { %>
        <tr><td colspan="5" style="text-align:center;color:var(--admin-text-muted)">No guides yet</td></tr>
      <% } %>
    </tbody>
  </table>
</div>
