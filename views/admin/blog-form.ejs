<div class="admin-page-head">
  <div class="admin-page-head-text">
    <div class="admin-crumbs"><a href="/admin">Admin</a> <span>/</span> <a href="/admin/blog">Blog</a> <span>/</span> <span><%= editing ? 'Edit' : 'New' %></span></div>
    <h1><%= editing ? 'Edit blog post' : 'New blog post' %></h1>
  </div>
  <div class="admin-page-head-actions">
    <a href="/admin/blog" class="admin-btn admin-btn-ghost">← Back to list</a>
  </div>
</div>

<form method="POST" action="<%= editing ? '/admin/blog/edit/' + post.id : '/admin/blog' %>">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <div class="admin-card">
    <h2>Post details</h2>
    <div class="admin-field-row">
      <div class="admin-field"><label for="title">Title (KA)</label><input type="text" id="title" name="title" class="admin-input" value="<%= post.title || '' %>" required></div>
      <div class="admin-field"><label for="title_en">Title (EN)</label><input type="text" id="title_en" name="title_en" class="admin-input" value="<%= post.title_en || '' %>"></div>
    </div>
    <div class="admin-field">
      <label for="slug">Slug</label>
      <input type="text" id="slug" name="slug" class="admin-input" value="<%= post.slug || '' %>">
      <div class="admin-field-help">Used in the URL. Auto-generated from title if left empty.</div>
    </div>
  </div>

  <div class="admin-card">
    <h2>Content (Markdown)</h2>
    <div class="admin-field-row">
      <div class="admin-field"><label for="content">Content (KA)</label><textarea id="content" name="content" class="admin-textarea" rows="14" style="font-family: 'JetBrains Mono', monospace; font-size: 13px"><%= post.content || '' %></textarea></div>
      <div class="admin-field"><label for="content_en">Content (EN)</label><textarea id="content_en" name="content_en" class="admin-textarea" rows="14" style="font-family: 'JetBrains Mono', monospace; font-size: 13px"><%= post.content_en || '' %></textarea></div>
    </div>
  </div>

  <div class="admin-card">
    <h2>Media &amp; metadata</h2>
    <div class="admin-field"><label for="coverImage">Cover image URL</label><input type="text" id="coverImage" name="coverImage" class="admin-input" value="<%= post.coverImage || '' %>" data-upload="single"></div>
    <div class="admin-field"><label for="tags">Tags</label><textarea id="tags" name="tags" class="admin-textarea" rows="3"><%= (post.tags || []).join('\n') %></textarea><div class="admin-field-help">One per line.</div></div>
    <div class="admin-field-row">
      <div class="admin-field">
        <label for="author">Author (Guide)</label>
        <select id="author" name="author" class="admin-select">
          <option value="">— None —</option>
          <% (typeof guides !== 'undefined' ? guides : []).forEach(g => { %>
            <option value="<%= g.id %>" <%= String(post.author) === String(g.id) ? 'selected' : '' %>><%= g.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="admin-field"><label for="publishedAt">Published date</label><input type="date" id="publishedAt" name="publishedAt" class="admin-input" value="<%= post.publishedAt || '' %>"></div>
    </div>
    <div class="admin-field"><label for="relatedHikeIds">Related hikes</label><textarea id="relatedHikeIds" name="relatedHikeIds" class="admin-textarea" rows="3"><%= (post.relatedHikeIds || []).join('\n') %></textarea><div class="admin-field-help">One hike ID per line.</div></div>
    <label class="admin-check">
      <input type="checkbox" name="published" value="true" <%= post.published ? 'checked' : '' %>>
      <div><strong>Published</strong><div style="color: var(--a-text-muted); font-size: 12px">Uncheck to save as draft (not visible publicly).</div></div>
    </label>
  </div>

  <div class="admin-form-actions">
    <button type="submit" class="admin-btn admin-btn-primary"><%= editing ? 'Update post' : 'Create post' %></button>
    <a href="/admin/blog" class="admin-btn admin-btn-ghost">Cancel</a>
  </div>
</form>
