<div class="admin-page-head">
  <div class="admin-page-head-text">
    <div class="admin-crumbs"><a href="/admin">Admin</a> <span>/</span> <span>Gallery</span></div>
    <h1>Gallery &amp; Adventures</h1>
    <p>Past adventure photo journals.</p>
  </div>
  <div class="admin-page-head-actions">
    <a href="/admin/gallery/new" class="admin-btn admin-btn-primary">+ New adventure</a>
  </div>
</div>

<% if (gallery && gallery.length) { %>
<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr>
        <th style="width: 60px">#</th>
        <th>Adventure</th>
        <th>Date</th>
        <th>Reorder</th>
        <th style="text-align: right">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% gallery.forEach((g, i) => { %>
        <tr>
          <td style="color: var(--a-text-dim); font-family: 'JetBrains Mono', monospace"><%= i + 1 %></td>
          <td>
            <div style="display: flex; gap: 12px; align-items: center">
              <img src="<%= g.mainImage %>" alt="" class="admin-table-thumb">
              <div>
                <div style="font-weight: 600"><a href="/admin/gallery/edit/<%= g.id %>"><%= g.title %></a></div>
              </div>
            </div>
          </td>
          <td style="font-size: 12px; color: var(--a-text-muted)"><%= g.date || '—' %></td>
          <td>
            <div style="display: inline-flex; gap: 4px">
              <% if (i > 0) { %>
                <form method="POST" action="/admin/gallery/reorder/<%= g.id %>/up" style="display: inline"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button type="submit" class="admin-btn admin-btn-outline admin-btn-sm" title="Move up">↑</button></form>
              <% } %>
              <% if (i < gallery.length - 1) { %>
                <form method="POST" action="/admin/gallery/reorder/<%= g.id %>/down" style="display: inline"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button type="submit" class="admin-btn admin-btn-outline admin-btn-sm" title="Move down">↓</button></form>
              <% } %>
            </div>
          </td>
          <td>
            <div class="admin-table-actions">
              <a href="/admin/gallery/edit/<%= g.id %>" class="admin-btn admin-btn-outline admin-btn-sm">Edit</a>
              <form method="POST" action="/admin/gallery/delete/<%= g.id %>" onsubmit="return confirm('Delete this adventure?')" style="display: inline">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="admin-btn admin-btn-danger admin-btn-sm">Delete</button>
              </form>
            </div>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>
<% } else { %>
  <div class="admin-card"><div class="admin-empty">
    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
    <p>No adventures yet. Start documenting your trips.</p>
    <a href="/admin/gallery/new" class="admin-btn admin-btn-primary" style="margin-top: 16px">+ New adventure</a>
  </div></div>
<% } %>
