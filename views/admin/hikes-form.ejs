<div class="admin-page-head">
  <div class="admin-page-head-text">
    <div class="admin-crumbs"><a href="/admin">Admin</a> <span>/</span> <a href="/admin/hikes">Hikes</a> <span>/</span> <span><%= editing ? 'Edit' : 'New' %></span></div>
    <h1><%= editing ? 'Edit hike' : 'New hike' %></h1>
    <p><%= editing ? 'Update this hike\'s content, pricing, and media.' : 'Create a new hiking tour.' %></p>
  </div>
  <div class="admin-page-head-actions">
    <a href="/admin/hikes" class="admin-btn admin-btn-ghost">← Back to list</a>
  </div>
</div>

<% if (typeof errors !== 'undefined' && errors && errors.length) { %>
  <div class="admin-flash admin-flash-error">
    <ul style="margin: 0; padding-left: 18px"><% errors.forEach(e => { %><li><%= e.msg %></li><% }) %></ul>
  </div>
<% } %>

<form method="POST" action="<%= editing ? '/admin/hikes/edit/' + hike.id : '/admin/hikes' %>">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <div class="admin-card">
    <h2>Identity</h2>
    <div class="admin-field">
      <label for="id">ID (slug)</label>
      <input type="text" id="id" name="id" class="admin-input" value="<%= hike.id || '' %>" required <%= editing ? 'readonly' : '' %>>
      <div class="admin-field-help">Used in the URL. Lowercase, dashes-only, no spaces.</div>
    </div>

    <div class="admin-field-row">
      <div class="admin-field"><label for="name">Name (KA)</label><input type="text" id="name" name="name" class="admin-input" value="<%= hike.name || '' %>" required></div>
      <div class="admin-field"><label for="name_en">Name (EN)</label><input type="text" id="name_en" name="name_en" class="admin-input" value="<%= hike.name_en || '' %>"></div>
    </div>

    <div class="admin-field-row-3">
      <div class="admin-field">
        <label for="type">Type</label>
        <select id="type" name="type" class="admin-select">
          <option value="day" <%= hike.type === 'day' ? 'selected' : '' %>>Day</option>
          <option value="multi-day" <%= hike.type === 'multi-day' ? 'selected' : '' %>>Multi-day</option>
          <option value="cultural" <%= hike.type === 'cultural' ? 'selected' : '' %>>Cultural</option>
        </select>
      </div>
      <div class="admin-field">
        <label for="difficulty">Difficulty</label>
        <select id="difficulty" name="difficulty" class="admin-select">
          <option value="easy" <%= hike.difficulty === 'easy' ? 'selected' : '' %>>Easy</option>
          <option value="medium" <%= hike.difficulty === 'medium' ? 'selected' : '' %>>Medium</option>
          <option value="hard" <%= hike.difficulty === 'hard' ? 'selected' : '' %>>Hard</option>
        </select>
      </div>
      <div class="admin-field">
        <label for="price">Price (₾)</label>
        <input type="number" id="price" name="price" class="admin-input" value="<%= hike.price || '' %>">
      </div>
    </div>

    <div class="admin-field-row-3">
      <div class="admin-field"><label for="distance">Distance</label><input type="text" id="distance" name="distance" class="admin-input" value="<%= hike.distance || '' %>"></div>
      <div class="admin-field"><label for="elevation">Elevation</label><input type="text" id="elevation" name="elevation" class="admin-input" value="<%= hike.elevation || '' %>"></div>
      <div class="admin-field"><label for="groupSize">Group size</label><input type="text" id="groupSize" name="groupSize" class="admin-input" value="<%= hike.groupSize || '' %>"></div>
    </div>

    <div class="admin-field-row">
      <div class="admin-field"><label for="duration">Duration (KA)</label><input type="text" id="duration" name="duration" class="admin-input" value="<%= hike.duration || '' %>"></div>
      <div class="admin-field"><label for="duration_en">Duration (EN)</label><input type="text" id="duration_en" name="duration_en" class="admin-input" value="<%= hike.duration_en || '' %>"></div>
    </div>

    <div class="admin-field-row">
      <div class="admin-field"><label for="region">Region (KA)</label><input type="text" id="region" name="region" class="admin-input" value="<%= hike.region || '' %>"></div>
      <div class="admin-field"><label for="region_en">Region (EN)</label><input type="text" id="region_en" name="region_en" class="admin-input" value="<%= hike.region_en || '' %>"></div>
    </div>

    <div class="admin-field">
      <label for="dates">Upcoming dates</label>
      <textarea id="dates" name="dates" class="admin-textarea" rows="3"><%= Array.isArray(hike.dates) ? hike.dates.join('\n') : (hike.dates || hike.date || '') %></textarea>
      <div class="admin-field-help">One date per line (YYYY-MM-DD).</div>
    </div>

    <label class="admin-check">
      <input type="checkbox" name="featured" value="true" <%= hike.featured ? 'checked' : '' %>>
      <div>
        <strong>Featured</strong>
        <div style="color: var(--a-text-muted); font-size: 12px">Shown on the homepage and highlighted across the site.</div>
      </div>
    </label>
  </div>

  <div class="admin-card">
    <h2>Copy</h2>
    <div class="admin-field-row">
      <div class="admin-field"><label for="summary">Summary (KA)</label><textarea id="summary" name="summary" class="admin-textarea" rows="2"><%= hike.summary || '' %></textarea></div>
      <div class="admin-field"><label for="summary_en">Summary (EN)</label><textarea id="summary_en" name="summary_en" class="admin-textarea" rows="2"><%= hike.summary_en || '' %></textarea></div>
    </div>
    <div class="admin-field-row">
      <div class="admin-field"><label for="description">Description (KA)</label><textarea id="description" name="description" class="admin-textarea" rows="6"><%= hike.description || '' %></textarea></div>
      <div class="admin-field"><label for="description_en">Description (EN)</label><textarea id="description_en" name="description_en" class="admin-textarea" rows="6"><%= hike.description_en || '' %></textarea></div>
    </div>
    <div class="admin-field-row">
      <div class="admin-field"><label for="highlights">Highlights (KA)</label><textarea id="highlights" name="highlights" class="admin-textarea" rows="4"><%= (hike.highlights || []).join('\n') %></textarea><div class="admin-field-help">One per line.</div></div>
      <div class="admin-field"><label for="highlights_en">Highlights (EN)</label><textarea id="highlights_en" name="highlights_en" class="admin-textarea" rows="4"><%= (hike.highlights_en || []).join('\n') %></textarea><div class="admin-field-help">One per line.</div></div>
    </div>
    <div class="admin-field-row">
      <div class="admin-field"><label for="included">Included (KA)</label><textarea id="included" name="included" class="admin-textarea" rows="4"><%= (hike.included || []).join('\n') %></textarea></div>
      <div class="admin-field"><label for="included_en">Included (EN)</label><textarea id="included_en" name="included_en" class="admin-textarea" rows="4"><%= (hike.included_en || []).join('\n') %></textarea></div>
    </div>
    <div class="admin-field-row">
      <div class="admin-field"><label for="notIncluded">Not included (KA)</label><textarea id="notIncluded" name="notIncluded" class="admin-textarea" rows="4"><%= (hike.notIncluded || []).join('\n') %></textarea></div>
      <div class="admin-field"><label for="notIncluded_en">Not included (EN)</label><textarea id="notIncluded_en" name="notIncluded_en" class="admin-textarea" rows="4"><%= (hike.notIncluded_en || []).join('\n') %></textarea></div>
    </div>
  </div>

  <div class="admin-card">
    <h2>Media</h2>
    <div class="admin-field"><label for="heroImage">Hero image URL</label><input type="text" id="heroImage" name="heroImage" class="admin-input" value="<%= hike.heroImage || '' %>" data-upload="single"></div>
    <div class="admin-field"><label for="cardImage">Card image URL</label><input type="text" id="cardImage" name="cardImage" class="admin-input" value="<%= hike.cardImage || '' %>" data-upload="single"></div>
    <div class="admin-field"><label for="images">Gallery images</label><textarea id="images" name="images" class="admin-textarea" rows="4" data-upload="multi"><%= (hike.images || []).join('\n') %></textarea><div class="admin-field-help">One URL per line.</div></div>
  </div>

  <div class="admin-card">
    <h2>Booking links</h2>
    <div class="admin-field"><label for="messengerLink">Messenger group chat</label><input type="url" id="messengerLink" name="messengerLink" class="admin-input" value="<%= hike.messengerLink || '' %>" placeholder="https://m.me/..."></div>
    <div class="admin-field"><label for="whatsappLink">WhatsApp group chat</label><input type="url" id="whatsappLink" name="whatsappLink" class="admin-input" value="<%= hike.whatsappLink || '' %>" placeholder="https://chat.whatsapp.com/..."></div>
  </div>

  <div class="admin-card">
    <h2>Route file (optional)</h2>
    <div class="admin-field">
      <label>Upload a KML / GPX / KMZ file</label>
      <input type="file" id="routeFileInput" accept=".kml,.gpx,.kmz" class="admin-input">
      <span id="routeStatus" class="upload-status admin-field-help"></span>
      <input type="hidden" id="routeData" name="routeData" value='<%= hike.route ? JSON.stringify(hike.route) : "" %>'>
      <div id="routePreviewMap" class="admin-map-container" style="margin-top: 12px; <%= (hike.route && hike.route.coordinates && hike.route.coordinates.length) ? '' : 'display:none;' %>"></div>
    </div>
  </div>

  <div class="admin-form-actions">
    <button type="submit" class="admin-btn admin-btn-primary"><%= editing ? 'Update hike' : 'Create hike' %></button>
    <a href="/admin/hikes" class="admin-btn admin-btn-ghost">Cancel</a>
  </div>
</form>
