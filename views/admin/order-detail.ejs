<div class="admin-header">
  <h1>Order <%= order.id %></h1>
  <a href="/admin/orders" class="btn btn-secondary">Back to Orders</a>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:2rem;margin-bottom:2rem;">
  <div class="admin-card">
    <h3 style="margin-bottom:1rem;">Customer</h3>
    <p><strong>Name:</strong> <%= order.customer ? order.customer.name : '—' %></p>
    <p><strong>Email:</strong> <%= order.customer ? order.customer.email : '—' %></p>
    <p><strong>Phone:</strong> <%= order.customer ? order.customer.phone : '—' %></p>
    <% if (order.customer && order.customer.address) { %>
      <p><strong>Address:</strong> <%= order.customer.address %></p>
    <% } %>
  </div>
  <div class="admin-card">
    <h3 style="margin-bottom:1rem;">Order Info</h3>
    <p><strong>Date:</strong> <%= order.createdAt ? new Date(order.createdAt).toLocaleString('en-GB') : '—' %></p>
    <p><strong>Payment:</strong> <%= order.paymentMethod || '—' %></p>
    <p><strong>Status:</strong> <span class="order-status status-<%= order.status || 'pending' %>"><%= order.status || 'pending' %></span></p>
    <form method="POST" action="/admin/orders/<%= order.id %>/status" style="margin-top:1rem;display:flex;gap:0.5rem;align-items:center;">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <select name="status" style="padding:0.4rem;">
        <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Pending</option>
        <option value="confirmed" <%= order.status === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
        <option value="paid" <%= order.status === 'paid' ? 'selected' : '' %>>Paid</option>
        <option value="shipped" <%= order.status === 'shipped' ? 'selected' : '' %>>Shipped</option>
        <option value="completed" <%= order.status === 'completed' ? 'selected' : '' %>>Completed</option>
        <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
      </select>
      <button type="submit" class="btn btn-primary btn-sm">Update</button>
    </form>
  </div>
</div>

<div class="admin-card">
  <h3 style="margin-bottom:1rem;">Items</h3>
  <table class="admin-table">
    <thead>
      <tr>
        <th>Product</th>
        <th>Price</th>
        <th>Qty</th>
        <th>Subtotal</th>
      </tr>
    </thead>
    <tbody>
      <% if (order.items && order.items.length) { %>
        <% order.items.forEach(item => { %>
          <tr>
            <td><%= item.name %></td>
            <td>&#8382;<%= item.price %></td>
            <td><%= item.quantity %></td>
            <td>&#8382;<%= (item.price * item.quantity).toFixed(2) %></td>
          </tr>
        <% }) %>
      <% } %>
      <tr style="font-weight:700;">
        <td colspan="3" style="text-align:right;">Total</td>
        <td>&#8382;<%= order.total || 0 %></td>
      </tr>
    </tbody>
  </table>
</div>
