<div class="admin-page-head">
  <div class="admin-page-head-text">
    <div class="admin-crumbs"><a href="/admin">Admin</a> <span>/</span> <a href="/admin/orders">Orders</a> <span>/</span> <span><%= order.id %></span></div>
    <h1>Order <span style="font-family: 'JetBrains Mono', monospace; color: var(--a-accent); font-size: 18px"><%= order.id %></span></h1>
    <p>Placed <%= order.createdAt ? new Date(order.createdAt).toLocaleString('en-GB') : '—' %></p>
  </div>
  <div class="admin-page-head-actions">
    <a href="/admin/orders" class="admin-btn admin-btn-ghost">← All orders</a>
  </div>
</div>

<div class="admin-grid-2">
  <div class="admin-card">
    <h2>Customer</h2>
    <div class="stack" style="font-size: 13px; line-height: 1.8">
      <div><span class="admin-muted">Name:</span> <strong><%= order.customer ? order.customer.name : '—' %></strong></div>
      <div><span class="admin-muted">Email:</span> <% if (order.customer) { %><a href="mailto:<%= order.customer.email %>"><%= order.customer.email %></a><% } else { %>—<% } %></div>
      <div><span class="admin-muted">Phone:</span> <% if (order.customer) { %><a href="tel:<%= order.customer.phone %>"><%= order.customer.phone %></a><% } else { %>—<% } %></div>
      <% if (order.customer && order.customer.address) { %>
        <div><span class="admin-muted">Address:</span><br><%= order.customer.address %></div>
      <% } %>
    </div>
  </div>

  <div class="admin-card">
    <h2>Order info</h2>
    <div class="stack" style="font-size: 13px; line-height: 1.8">
      <div><span class="admin-muted">Payment:</span> <strong><%= order.paymentMethod || '—' %></strong></div>
      <div><span class="admin-muted">Status:</span>
        <% var status = order.status || 'pending'; %>
        <% if (status === 'completed' || status === 'paid' || status === 'delivered') { %>
          <span class="admin-badge admin-badge-success"><%= status %></span>
        <% } else if (status === 'cancelled') { %>
          <span class="admin-badge admin-badge-danger"><%= status %></span>
        <% } else if (status === 'shipped' || status === 'processing' || status === 'confirmed') { %>
          <span class="admin-badge admin-badge-info"><%= status %></span>
        <% } else { %>
          <span class="admin-badge admin-badge-warn"><%= status %></span>
        <% } %>
      </div>
    </div>
    <form method="POST" action="/admin/orders/<%= order.id %>/status" style="margin-top: 16px; display: flex; gap: 8px; align-items: center">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <select name="status" class="admin-select" style="flex: 1; min-height: 36px">
        <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Pending</option>
        <option value="confirmed" <%= order.status === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
        <option value="paid" <%= order.status === 'paid' ? 'selected' : '' %>>Paid</option>
        <option value="shipped" <%= order.status === 'shipped' ? 'selected' : '' %>>Shipped</option>
        <option value="completed" <%= order.status === 'completed' ? 'selected' : '' %>>Completed</option>
        <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
      </select>
      <button type="submit" class="admin-btn admin-btn-primary admin-btn-sm">Update</button>
    </form>
  </div>
</div>

<div class="admin-card">
  <div class="admin-card-head">
    <h2>Line items</h2>
    <div style="font-family: 'JetBrains Mono', monospace; color: var(--a-accent); font-size: 18px; font-weight: 700">₾<%= order.total || 0 %></div>
  </div>
  <div class="admin-table-wrap" style="margin-bottom: 0">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Product</th>
          <th>Price</th>
          <th>Qty</th>
          <th style="text-align: right">Subtotal</th>
        </tr>
      </thead>
      <tbody>
        <% if (order.items && order.items.length) { %>
          <% order.items.forEach(item => { %>
            <tr>
              <td style="font-weight: 500"><%= item.name %></td>
              <td>₾<%= item.price %></td>
              <td><%= item.quantity %></td>
              <td style="text-align: right; font-weight: 600">₾<%= (item.price * item.quantity).toFixed(2) %></td>
            </tr>
          <% }); %>
        <% } %>
        <tr>
          <td colspan="3" style="text-align: right; font-weight: 600; border-top: 2px solid var(--a-border-2)">Total</td>
          <td style="text-align: right; font-weight: 700; color: var(--a-accent); font-size: 16px; border-top: 2px solid var(--a-border-2)">₾<%= order.total || 0 %></td>
        </tr>
      </tbody>
    </table>
  </div>
</div>
