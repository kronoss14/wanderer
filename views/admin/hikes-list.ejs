<div class="admin-page-head">
  <div class="admin-page-head-text">
    <div class="admin-crumbs"><a href="/admin">Admin</a> <span>/</span> <span>Hikes</span></div>
    <h1>Hikes</h1>
    <p>Manage hiking tours, pricing, dates, and featured status.</p>
  </div>
  <div class="admin-page-head-actions">
    <a href="/admin/hikes/new" class="admin-btn admin-btn-primary">+ New hike</a>
  </div>
</div>

<% if (hikes && hikes.length) { %>
<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr>
        <th>Hike</th>
        <th>Type</th>
        <th>Difficulty</th>
        <th>Dates</th>
        <th>Price</th>
        <th>Featured</th>
        <th style="text-align: right">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% hikes.forEach(h => { %>
        <tr>
          <td>
            <div style="display: flex; gap: 12px; align-items: center">
              <% if (h.cardImage || h.heroImage) { %><img src="<%= h.cardImage || h.heroImage %>" alt="" class="admin-table-thumb"><% } %>
              <div>
                <div style="font-weight: 600"><a href="/admin/hikes/edit/<%= h.id %>"><%= h.name %></a></div>
                <div style="font-size: 12px; color: var(--a-text-muted)"><%= h.name_en || '' %></div>
              </div>
            </div>
          </td>
          <td><span class="admin-badge"><%= h.type || '—' %></span></td>
          <td>
            <% if (h.difficulty === 'easy') { %><span class="admin-badge admin-badge-success">Easy</span>
            <% } else if (h.difficulty === 'hard') { %><span class="admin-badge admin-badge-danger">Hard</span>
            <% } else if (h.difficulty === 'medium') { %><span class="admin-badge admin-badge-warn">Medium</span>
            <% } else { %><span class="admin-badge">—</span><% } %>
          </td>
          <td style="font-size: 12px; color: var(--a-text-muted)">
            <%= Array.isArray(h.dates) && h.dates.length ? h.dates.slice(0,2).join(', ') : (h.date || '—') %>
          </td>
          <td style="font-weight: 600; color: var(--a-accent)">₾<%= h.price %></td>
          <td><% if (h.featured) { %><span class="admin-badge admin-badge-accent">★ Featured</span><% } else { %><span class="admin-muted">—</span><% } %></td>
          <td>
            <div class="admin-table-actions">
              <a href="/admin/hikes/edit/<%= h.id %>" class="admin-btn admin-btn-outline admin-btn-sm">Edit</a>
              <form method="POST" action="/admin/hikes/delete/<%= h.id %>" onsubmit="return confirm('Delete “<%= h.name %>”? This cannot be undone.')" style="display: inline">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="admin-btn admin-btn-danger admin-btn-sm">Delete</button>
              </form>
            </div>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>
<% } else { %>
  <div class="admin-card">
    <div class="admin-empty">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"/></svg>
      <p>No hikes yet. Add your first hiking tour to get started.</p>
      <a href="/admin/hikes/new" class="admin-btn admin-btn-primary" style="margin-top: 16px">+ New hike</a>
    </div>
  </div>
<% } %>
