<div class="admin-page-head">
  <div class="admin-page-head-text">
    <div class="admin-crumbs"><a href="/admin">Admin</a> <span>/</span> <span>Orders</span></div>
    <h1>Orders</h1>
    <p>Shop orders from customers. Click an order ID for full details.</p>
  </div>
</div>

<% if (orders && orders.length) { %>
<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr>
        <th>Order</th>
        <th>Customer</th>
        <th>Items</th>
        <th>Total</th>
        <th>Payment</th>
        <th>Status</th>
        <th>Date</th>
      </tr>
    </thead>
    <tbody>
      <% orders.forEach(o => { %>
        <tr>
          <td><a href="/admin/orders/<%= o.id %>" style="font-family: 'JetBrains Mono', monospace; font-size: 12px"><%= o.id %></a></td>
          <td style="font-weight: 500"><%= o.customer ? o.customer.name : '—' %></td>
          <td style="color: var(--a-text-muted); font-size: 12px"><%= o.items ? o.items.length : 0 %> <%= (o.items && o.items.length === 1) ? 'item' : 'items' %></td>
          <td style="font-weight: 600; color: var(--a-accent)">₾<%= o.total || 0 %></td>
          <td style="font-size: 12px; color: var(--a-text-muted)"><%= o.paymentMethod || '—' %></td>
          <td>
            <% var status = o.status || 'pending'; %>
            <% if (status === 'completed' || status === 'delivered' || status === 'paid') { %>
              <span class="admin-badge admin-badge-success"><%= status %></span>
            <% } else if (status === 'cancelled' || status === 'failed') { %>
              <span class="admin-badge admin-badge-danger"><%= status %></span>
            <% } else if (status === 'shipped' || status === 'processing') { %>
              <span class="admin-badge admin-badge-info"><%= status %></span>
            <% } else { %>
              <span class="admin-badge admin-badge-warn"><%= status %></span>
            <% } %>
          </td>
          <td style="font-size: 12px; color: var(--a-text-muted)"><%= o.createdAt ? new Date(o.createdAt).toLocaleDateString('en-GB') : '—' %></td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>
<% } else { %>
  <div class="admin-card"><div class="admin-empty">
    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
    <p>No orders yet. They'll appear here as customers check out.</p>
  </div></div>
<% } %>
