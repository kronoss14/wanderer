<div class="admin-header">
  <h1><%= editing ? 'Edit Adventure' : 'New Adventure' %></h1>
</div>

<form class="admin-form" method="POST" action="<%= editing ? '/admin/gallery/edit/' + item.id : '/admin/gallery' %>">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <div class="form-lang-row">
    <div class="form-group">
      <label for="title">Title (KA)</label>
      <input type="text" id="title" name="title" value="<%= item.title || '' %>" required>
    </div>
    <div class="form-group">
      <label for="title_en">Title (EN)</label>
      <input type="text" id="title_en" name="title_en" value="<%= item.title_en || '' %>">
    </div>
  </div>

  <div class="form-group">
    <label for="date">Date</label>
    <input type="date" id="date" name="date" value="<%= item.date || '' %>" required>
  </div>

  <div class="form-lang-row">
    <div class="form-group">
      <label for="description">Description (KA)</label>
      <textarea id="description" name="description" rows="4"><%= item.description || '' %></textarea>
    </div>
    <div class="form-group">
      <label for="description_en">Description (EN)</label>
      <textarea id="description_en" name="description_en" rows="4"><%= item.description_en || '' %></textarea>
    </div>
  </div>

  <div class="form-group">
    <label for="mainImage">Main Image URL</label>
    <input type="text" id="mainImage" name="mainImage" value="<%= item.mainImage || '' %>" required data-upload="single">
  </div>

  <div class="form-group">
    <label for="images">Additional Images (one URL per line)</label>
    <textarea id="images" name="images" rows="6" data-upload="multi"><%= Array.isArray(item.images) ? item.images.join('\n') : (item.images || '') %></textarea>
  </div>

  <div class="form-group">
    <label for="hikeId">Linked Hike (optional)</label>
    <select id="hikeId" name="hikeId">
      <option value="">— None —</option>
      <% (typeof hikes !== 'undefined' ? hikes : []).forEach(h => { %>
        <option value="<%= h.id %>" <%= item.hikeId === h.id ? 'selected' : '' %>><%= h.name %></option>
      <% }) %>
    </select>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary"><%= editing ? 'Update Adventure' : 'Create Adventure' %></button>
    <a href="/admin/gallery" class="btn btn-secondary">Cancel</a>
  </div>
</form>
