<div class="admin-header">
  <h1><%= editing ? 'Edit Gallery Item' : 'New Gallery Item' %></h1>
</div>

<form class="admin-form" method="POST" action="<%= editing ? '/admin/gallery/edit/' + item.id : '/admin/gallery' %>">
  <div class="form-group">
    <label for="title">Title</label>
    <input type="text" id="title" name="title" value="<%= item.title || '' %>" required>
  </div>

  <div class="form-group">
    <label for="category">Category</label>
    <select id="category" name="category">
      <option value="landscapes" <%= item.category === 'landscapes' ? 'selected' : '' %>>Landscapes</option>
      <option value="hiking" <%= item.category === 'hiking' ? 'selected' : '' %>>Hiking</option>
      <option value="culture" <%= item.category === 'culture' ? 'selected' : '' %>>Culture</option>
    </select>
  </div>

  <div class="form-group">
    <label for="location">Location</label>
    <input type="text" id="location" name="location" value="<%= item.location || '' %>">
  </div>

  <div class="form-group">
    <label for="image">Image URL</label>
    <input type="url" id="image" name="image" value="<%= item.image || '' %>" required>
  </div>

  <div class="form-group">
    <label for="thumbnail">Thumbnail URL</label>
    <input type="url" id="thumbnail" name="thumbnail" value="<%= item.thumbnail || '' %>" required>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary"><%= editing ? 'Update Item' : 'Create Item' %></button>
    <a href="/admin/gallery" class="btn btn-secondary">Cancel</a>
  </div>
</form>
