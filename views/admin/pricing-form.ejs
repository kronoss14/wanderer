<div class="admin-page-head">
  <div class="admin-page-head-text">
    <div class="admin-crumbs"><a href="/admin">Admin</a> <span>/</span> <a href="/admin/pricing">Pricing</a> <span>/</span> <span><%= editing ? 'Edit' : 'New' %></span></div>
    <h1><%= editing ? 'Edit pricing tier' : 'New pricing tier' %></h1>
  </div>
  <div class="admin-page-head-actions">
    <a href="/admin/pricing" class="admin-btn admin-btn-ghost">← Back to list</a>
  </div>
</div>

<form method="POST" action="<%= editing ? '/admin/pricing/edit/' + tier.id : '/admin/pricing' %>">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <div class="admin-card">
    <h2>Tier</h2>
    <div class="admin-field-row">
      <div class="admin-field"><label for="tier">Name (KA)</label><input type="text" id="tier" name="tier" class="admin-input" value="<%= tier.tier || '' %>" required></div>
      <div class="admin-field"><label for="tier_en">Name (EN)</label><input type="text" id="tier_en" name="tier_en" class="admin-input" value="<%= tier.tier_en || '' %>"></div>
    </div>
    <div class="admin-field"><label for="price">Numeric price (leave empty for custom)</label><input type="number" id="price" name="price" class="admin-input" value="<%= tier.price != null ? tier.price : '' %>"></div>
    <div class="admin-field-row">
      <div class="admin-field"><label for="priceLabel">Price label (KA)</label><input type="text" id="priceLabel" name="priceLabel" class="admin-input" value="<%= tier.priceLabel || '' %>" required></div>
      <div class="admin-field"><label for="priceLabel_en">Price label (EN)</label><input type="text" id="priceLabel_en" name="priceLabel_en" class="admin-input" value="<%= tier.priceLabel_en || '' %>"></div>
    </div>
    <div class="admin-field-row">
      <div class="admin-field"><label for="unit">Unit (KA)</label><input type="text" id="unit" name="unit" class="admin-input" value="<%= tier.unit || '' %>"></div>
      <div class="admin-field"><label for="unit_en">Unit (EN)</label><input type="text" id="unit_en" name="unit_en" class="admin-input" value="<%= tier.unit_en || '' %>"></div>
    </div>
    <div class="admin-field-row">
      <div class="admin-field"><label for="description">Description (KA)</label><textarea id="description" name="description" class="admin-textarea" rows="3"><%= tier.description || '' %></textarea></div>
      <div class="admin-field"><label for="description_en">Description (EN)</label><textarea id="description_en" name="description_en" class="admin-textarea" rows="3"><%= tier.description_en || '' %></textarea></div>
    </div>
    <div class="admin-field-row">
      <div class="admin-field"><label for="features">Features (KA)</label><textarea id="features" name="features" class="admin-textarea" rows="5"><%= (tier.features || []).join('\n') %></textarea><div class="admin-field-help">One per line.</div></div>
      <div class="admin-field"><label for="features_en">Features (EN)</label><textarea id="features_en" name="features_en" class="admin-textarea" rows="5"><%= (tier.features_en || []).join('\n') %></textarea><div class="admin-field-help">One per line.</div></div>
    </div>
    <div class="admin-field-row">
      <div class="admin-field"><label for="cta">CTA text (KA)</label><input type="text" id="cta" name="cta" class="admin-input" value="<%= tier.cta || '' %>"></div>
      <div class="admin-field"><label for="cta_en">CTA text (EN)</label><input type="text" id="cta_en" name="cta_en" class="admin-input" value="<%= tier.cta_en || '' %>"></div>
    </div>
    <label class="admin-check">
      <input type="checkbox" name="highlighted" value="true" <%= tier.highlighted ? 'checked' : '' %>>
      <div><strong>Highlighted</strong><div style="color: var(--a-text-muted); font-size: 12px">Marks this as the primary/recommended tier.</div></div>
    </label>
  </div>

  <div class="admin-form-actions">
    <button type="submit" class="admin-btn admin-btn-primary"><%= editing ? 'Update' : 'Create' %></button>
    <a href="/admin/pricing" class="admin-btn admin-btn-ghost">Cancel</a>
  </div>
</form>
